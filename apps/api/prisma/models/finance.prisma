// Legacy: COA, GL, JOURNALS, FINANCIAL_YEAR, ACCOUNT_GROUP, ACCOUNT_TYPES, STANDARD_ACCOUNTS, CLAIMS

model Coa {
  COA_ID                 Int      @id @default(autoincrement())
  PARENT_ID              Int?
  COA_NAME               String?  @db.VarChar(255)
  COA_CODE               String?  @db.VarChar(50)
  COA_TYPE               String?  @db.VarChar(50)
  CATEGORY               String?  @db.VarChar(50)
  CONTROL_HEAD           String?  @db.VarChar(50)
  IS_STANDARD            String?  @db.VarChar(10)
  USED_IN_BS             String?  @db.VarChar(10)
  USED_IN_IS             String?  @db.VarChar(10)
  CURRENT_BALANCE        Decimal? @db.Decimal(18, 2)
  OPENING_BAL            Decimal? @db.Decimal(18, 2)
  OLD_ACCOUNT_NO         String?  @db.VarChar(50)
  COA_LEVEL              Int?
  USE_FLAG               String?  @db.VarChar(10)
  OLD_COA_ID             Int?
  CLOSE_FLAG             String?  @db.VarChar(10)
  BUDGET_AMOUNT          Decimal? @db.Decimal(18, 2)
  REASON_REJECTION       String?  @db.VarChar(500)
  ACTUAL_BUDGETED_AMOUNT Decimal? @db.Decimal(18, 2)
  ACCOUNT_STATUS         String?  @db.VarChar(50)
  P_L_ID                 Int?
  INTEREST_ACCRUAL       String?  @db.VarChar(10)
  IS_CHECKING            String?  @db.VarChar(10)

  accountTypes     AccountTypes[]
  standardAccounts StandardAccounts[]
  glOpeningBal     GlOpeningBal[]
  items            Items[]

  @@map("COA")
}

model AccountGroup {
  ACCOUNT_GROUP_ID Int       @id @default(autoincrement())
  GROUP_NAME       String?   @db.VarChar(255)
  DESCRIPTION      String?   @db.VarChar(500)
  ACCOUNT_NO       String?   @db.VarChar(50)
  CREATED_BY       String?   @db.VarChar(100)
  CREATED_DATE     DateTime?
  MODIFIED_BY      String?   @db.VarChar(100)
  MODIFIED_DATE    DateTime?

  @@map("ACCOUNT_GROUP")
}

model AccountTypes {
  ACCOUNT_TYPE_ID   Int     @id @default(autoincrement())
  ACCOUNT_TYPE_NAME String? @db.VarChar(100)
  COA_ID            Int?
  BRANCH_ID         Int?

  coa Coa? @relation(fields: [COA_ID], references: [COA_ID])

  @@map("ACCOUNT_TYPES")
}

model FinancialYear {
  FINANCIAL_YEAR_ID   Int       @id @default(autoincrement())
  FINANCIAL_YEAR_NAME String?   @db.VarChar(100)
  START_DATE          DateTime?
  END_DATE            DateTime?
  FLAG                String?   @db.VarChar(10)

  gl       Gl[]
  journals Journals[]

  @@map("FINANCIAL_YEAR")
}

model Gl {
  GL_ID              Int       @id @default(autoincrement())
  BATCH_NO           String?   @db.VarChar(50)
  DESCRIPTION        String?   @db.VarChar(500)
  HEAD               String?   @db.VarChar(50)
  SUBHEAD            String?   @db.VarChar(50)
  DR_CR              String?   @db.VarChar(10)
  DEBIT              Decimal?  @db.Decimal(18, 2)
  CREDIT             Decimal?  @db.Decimal(18, 2)
  BALANCE            Decimal?  @db.Decimal(18, 2)
  FINANCIAL_YEAR_ID  Int?
  CREATED_DATE       DateTime?
  CREATED_BY         String?   @db.VarChar(100)
  REFE               String?   @db.VarChar(100)
  TELLER             String?   @db.VarChar(100)
  INVOICE            String?   @db.VarChar(100)
  IS_REVERSE         String?   @db.VarChar(10)
  INTEREST_RATE      Decimal?  @db.Decimal(8, 4)
  INTEREST_VALUE     Decimal?  @db.Decimal(14, 2)
  VALUE_DATE         DateTime?
  INTEREST_FLAG      String?   @db.VarChar(10)
  BRANCH_ID          Int?
  INTEREST_TO_DATE   DateTime?
  TRANS_TYPE         String?   @db.VarChar(50)
  TRANS_METHOD       String?   @db.VarChar(50)
  BANK_ID            Int?
  BANK_SORT_CODE     String?   @db.VarChar(50)
  BANK_ACCT_NAME     String?   @db.VarChar(255)
  BANK_ACCT_NO       String?   @db.VarChar(50)
  ARREARS_POSTION    String?   @db.VarChar(50)
  ARREARS_AGE        Int?

  financialYear FinancialYear? @relation(fields: [FINANCIAL_YEAR_ID], references: [FINANCIAL_YEAR_ID])

  @@index([FINANCIAL_YEAR_ID])
  @@map("GL")
}

model GlOpeningBal {
  GL_OPENING_BAL_ID      Int       @id @default(autoincrement())
  COA_ID                 Int?
  OPENING_BAL            Decimal?  @db.Decimal(18, 2)
  BRANCH_ID              Int?
  F_YEAR_ID              Int?
  OPENING_DATE           DateTime?
  CREATED_DATE           DateTime?
  CREATED_BY             String?   @db.VarChar(100)
  MODIFIED_BY            String?   @db.VarChar(100)
  MODIFIED_DATE          DateTime?
  CURRENT_BAL            Decimal?  @db.Decimal(18, 2)
  BUDGET_AMOUNT          Decimal?  @db.Decimal(18, 2)
  ACTUAL_BUDGETED_AMOUNT Decimal?  @db.Decimal(18, 2)

  coa Coa? @relation(fields: [COA_ID], references: [COA_ID])

  @@map("GL_OPENING_BAL")
}

model Journals {
  JOURNAL_ID         Int       @id @default(autoincrement())
  BATCH_NO           String?   @db.VarChar(50)
  DESCRIPTION        String?   @db.VarChar(500)
  HEAD               String?   @db.VarChar(50)
  SUBHEAD            String?   @db.VarChar(50)
  CR_DR              String?   @db.VarChar(10)
  AMOUNT             Decimal?  @db.Decimal(18, 2)
  FINANCIAL_YEAR_ID  Int?
  CREATE_DATE        DateTime?
  CREATED_BY         String?   @db.VarChar(100)
  PASS_FLAG          String?   @db.VarChar(10)
  REFE               String?   @db.VarChar(100)
  TELLER             String?   @db.VarChar(100)
  INVOICE            String?   @db.VarChar(100)
  BRANCH_ID          Int?
  WINDOW_ID          Int?
  VALUE_DATE         DateTime?
  INTEREST_FLAG      String?   @db.VarChar(10)
  TRANS_TYPE         String?   @db.VarChar(50)
  AAE_ID             Int?
  TRANS_METHOD       String?   @db.VarChar(50)
  BANK_ID            Int?
  BANK_SORT_CODE     String?   @db.VarChar(50)
  BANK_ACCT_NAME     String?   @db.VarChar(255)
  BANK_ACCT_NO       String?   @db.VarChar(50)
  TRANS_CODE         String?   @db.VarChar(50)
  I_OUTSTANDING      Decimal?  @db.Decimal(14, 2)
  P_OUTSTANDING      Decimal?  @db.Decimal(14, 2)

  financialYear FinancialYear? @relation(fields: [FINANCIAL_YEAR_ID], references: [FINANCIAL_YEAR_ID])

  @@map("JOURNALS")
}

model StandardAccounts {
  STANDARD_ACCOUNT_ID Int       @id @default(autoincrement())
  COA_ID              Int?
  ACCOUNT_NO_SHORT    String?   @db.VarChar(50)
  CURRENT_BALANCE     Decimal?  @db.Decimal(18, 2)
  CREATED_BY          String?   @db.VarChar(100)
  LAST_MODIFIED_BY    String?   @db.VarChar(100)
  CREATED_DATE        DateTime?
  LAST_MODIFIED_DATE  DateTime?
  APPROVED_BY         String?   @db.VarChar(100)
  ACCOUNT_TYPE        String?   @db.VarChar(50)
  BRANCH_ID           Int?
  STATUS              String?   @db.VarChar(50)
  OLD_ACCOUNT_NO      String?   @db.VarChar(50)
  PICS                Bytes?
  MIME                String?   @db.VarChar(100)
  FILENAME            String?   @db.VarChar(255)
  GROUP_ID            Int?
  ACCOUNT_NAME        String?   @db.VarChar(255)
  ADDRESS             String?   @db.VarChar(500)
  PHONE_NUMBER        String?   @db.VarChar(50)
  BILLINGSHEET_ID     Int?
  HMO_TYPE            String?   @db.VarChar(50)
  SUB_ACCT_NAME       String?   @db.VarChar(255)
  PERSON_ID           Int?
  INTEREST_BALANCE    Decimal?  @db.Decimal(18, 2)
  INTEREST_RATE       Decimal?  @db.Decimal(8, 4)
  DEPOSIT_TYPE        String?   @db.VarChar(50)
  COT                 String?   @db.VarChar(50)

  coa Coa? @relation(fields: [COA_ID], references: [COA_ID])

  @@map("STANDARD_ACCOUNTS")
}

model Claims {
  CLAIM_ID      Int       @id @default(autoincrement())
  PERSON_ID     Int?
  AGE           Int?
  HMO_ID        Int?
  CLAIM_TYPE    String?   @db.VarChar(50)
  CREATED_BY    String?   @db.VarChar(100)
  CREATED_DATE  DateTime?
  UPDATED_BY    String?   @db.VarChar(100)
  UPDATED_DATE  DateTime?
  CLAIM_PERIOD  String?   @db.VarChar(50)

  person  Persons?       @relation(fields: [PERSON_ID], references: [PERSON_ID])
  details ClaimDetails[]

  @@index([PERSON_ID])
  @@map("CLAIMS")
}

model ClaimDetails {
  CLAIM_DETAIL_ID    Int      @id @default(autoincrement())
  CLAIM_ID           Int?
  AUTHORIZATION_CODE String?  @db.VarChar(100)
  BILL_DETAIL_ID     Int?
  ADMISSION_ID       Int?
  ITEM_ID            Int?
  QTY                Decimal? @db.Decimal(12, 2)
  UNIT_PRICE         Decimal? @db.Decimal(12, 2)
  TOTAL              Decimal? @db.Decimal(12, 2)
  CLAIM_CLASS        String?  @db.VarChar(50)
  DIAGNOSIS_ID       Int?

  claim     Claims?      @relation(fields: [CLAIM_ID], references: [CLAIM_ID])
  billDetail BillDetials? @relation(fields: [BILL_DETAIL_ID], references: [BILL_DETAIL_ID])
  admission Admission?   @relation(fields: [ADMISSION_ID], references: [ADMISSION_ID])
  item      Items?       @relation(fields: [ITEM_ID], references: [ITEM_ID])

  @@index([CLAIM_ID])
  @@map("CLAIM_DETAILS")
}

model InsurancePolicy {
  INSURANCE_POLICY_ID  Int      @id @default(autoincrement())
  INSURANCE_COMPANY_ID Int?
  ITEM_CATEGORY        String?  @db.VarChar(100)
  PATIENT_VAL          Decimal? @db.Decimal(8, 2)
  INSURANCE_VAL        Decimal? @db.Decimal(8, 2)

  @@map("INSURANCE_POLICY")
}

model Banks {
  BANK_ID          Int     @id @default(autoincrement())
  BANK_NAME        String? @db.VarChar(255)
  ADDRESS          String? @db.VarChar(500)
  FMBN_BANK_ACCT_NO String? @db.VarChar(50)
  BANK_SORT_CODE   String? @db.VarChar(50)

  forms Forms[]

  @@map("BANKS")
}
