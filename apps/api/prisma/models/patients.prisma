  SBU                      String?   @db.VarChar(50)
  HOSPITAL_ID              Int?
  BRANCH_ID                Int?
  E_MAIL                   String?   @db.VarChar(255)
  PERSON_GROUP_ID          Int?
  BLOOD_GROUP              String?   @db.VarChar(20)
  DEATH_DATE               DateTime?
  DEATH_CAUSE              String?   @db.VarChar(500)
  IS_DEATH                 String?   @db.VarChar(10)
  GLOBAL_PERSON_ID         Int?
