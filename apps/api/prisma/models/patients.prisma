  ACCOUNT_TYPE             String?   @db.VarChar(50)
  PATIENT_TYPE             String?   @db.VarChar(50)
  SERVICE_NO               String?   @db.VarChar(50)
  RANK                     String?   @db.VarChar(50)
  UNIT                     String?   @db.VarChar(50)
  PRIMARY_CONSULTANT       String?   @db.VarChar(255)

