  ETHNIC_GROUP             String?   @db.VarChar(50)
  HUSBAND_NAME             String?   @db.VarChar(255)
  HUSBAND_OCCUPATION       String?   @db.VarChar(100)
  HUSBAND_EMPLOYER         String?   @db.VarChar(255)
  HUSBAND_TELL             String?   @db.VarChar(50)
  STATUS                   String?   @db.VarChar(50)
  NHIS_REG_TYPE            String?   @db.VarChar(50)
  EXPIRED_DATE             DateTime?
  DISCONTINUE_FLAG         String?   @db.VarChar(10)
  CREATED_BY               String?   @db.VarChar(100)
  CREATED_DATE             DateTime?
  UPDATED_BY               String?   @db.VarChar(100)
  UPDATED_DATE             DateTime?
  WALLET_ACCT_ID           Int?
  LOAN_ACCT_ID             Int?
  MIDDLE_NAME              String?   @db.VarChar(100)
  IDENTITY_TYPE            String?   @db.VarChar(50)
  IDENTITY_NO              String?   @db.VarChar(100)
  BIOMETRIC_NO             String?   @db.VarChar(100)
  PRINCIPAL_DEPENDANT      String?   @db.VarChar(10)
