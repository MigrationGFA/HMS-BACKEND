// Legacy: FORMS (staff), DESIGNATION, UNITS, SECTIONS, TRANSFER, PROMOTIONS, DOCTORS

model Forms {
  FORM_ID                  Int       @id @default(autoincrement())
  SEX                      String?   @db.VarChar(20)
  DATE_OF_BIRTH            DateTime?
  LGA_OF_ORIGIN            String?   @db.VarChar(100)
  STATE_OF_ORIGIN          String?   @db.VarChar(100)
  RELIGION                 String?   @db.VarChar(50)
  MARITAL_STATUS           String?   @db.VarChar(20)
  PRESENT_ADDRESS          String?   @db.VarChar(500)
  FIRST_NAME               String?   @db.VarChar(100)
  MIDDLE_NAME              String?   @db.VarChar(100)
  LAST_NAME                String?   @db.VarChar(100)
  PICTUER                  Bytes?
  REG_DATE                 DateTime?
  MIME_TYPE                String?   @db.VarChar(100)
  PHONE                    String?   @db.VarChar(50)
  E_MAIL                   String?   @db.VarChar(255)
  FILE_NAME                String?   @db.VarChar(255)
  CREATED_BY               String?   @db.VarChar(100)
  GRADE                    String?   @db.VarChar(50)
  STEP                     String?   @db.VarChar(50)
  DEPARTMENT_ID            Int?
  BANK_ID                  Int?
  BANK_ACCOUNT_NAME        String?   @db.VarChar(255)
  BANK_ACCOUNT_NO          String?   @db.VarChar(50)
  BRANCH_ID                Int?
  PASS_FLAG                String?   @db.VarChar(10)
  STAFF_NO                 String?   @unique @db.VarChar(50)
  DESIGNATION_ID           Int?
  DATE_OF_APPOINTMENT      DateTime?
  PLACE_OF_BIRTH           String?   @db.VarChar(100)
  NO_OF_DEPENDENTS         Int?
  NO_OF_CHILDREN           Int?
  NATIONALITY              String?   @db.VarChar(100)
  BLOOD_GROUP              String?   @db.VarChar(20)
  NATIONAL_ID_NO           String?   @db.VarChar(50)
  NEXT_OF_KIN_NAME         String?   @db.VarChar(255)
  ADDRESS_OF_NEXT_OF_KIN   String?   @db.VarChar(500)
  PFA                      String?   @db.VarChar(100)
  SALARY_TABLE_ID          Int?
  STATUS                   String?   @db.VarChar(50)
  UNIT_ID                  Int?
  SECTION_ID               Int?
  CREATED_DATE             DateTime?
  MODIFIED_BY              String?   @db.VarChar(100)
  MODIFIED_DATE            DateTime?
  ENTRY_QUALIFICATION      String?   @db.VarChar(255)
  FIRST_POSITION           String?   @db.VarChar(100)
  FIRST_APP_PLACE          String?   @db.VarChar(100)
  FIRST_GRADE              String?   @db.VarChar(50)
  DATE_CONFIRMATION        DateTime?
  PASSPORT_NO              String?   @db.VarChar(50)
  DRIVING_LICENSE_NO       String?   @db.VarChar(50)
  BANK_SORT_CODE           String?   @db.VarChar(50)

  bank        Banks?       @relation(fields: [BANK_ID], references: [BANK_ID])
  designation Designation? @relation(fields: [DESIGNATION_ID], references: [DESIGNATION_ID])
  unit        Units?       @relation(fields: [UNIT_ID], references: [UNIT_ID])
  section     Sections?    @relation(fields: [SECTION_ID], references: [SECTION_ID])
  users       Users[]

  @@index([STAFF_NO])
  @@map("FORMS")
}

model Designation {
  DESIGNATION_ID            Int     @id @default(autoincrement())
  DESIGNATION_NAME          String? @db.VarChar(255)
  SHORT_NAME_OF_DESIGNATION String? @db.VarChar(50)
  CODE_OF_DESIGNATION       String? @db.VarChar(50)
  LEVEL_OF_DESIGNATION      Int?

  forms Forms[]

  @@map("DESIGNATION")
}

model Units {
  UNIT_ID        Int       @id @default(autoincrement())
  UNIT_NAME      String?   @db.VarChar(255)
  CREATED_BY     String?   @db.VarChar(100)
  CREATED_DATE   DateTime?
  MODIFIED_BY    String?   @db.VarChar(100)
  MODIFIED_DATE  DateTime?

  sections Sections[]
  forms    Forms[]

  @@map("UNITS")
}

model Sections {
  SECTION_ID     Int       @id @default(autoincrement())
  UNIT_ID        Int?
  SECTION_NAME   String?   @db.VarChar(255)
  CREATED_BY     String?   @db.VarChar(100)
  CREATED_DATE   DateTime?
  MODIFIED_BY    String?   @db.VarChar(100)
  MODIFIED_DATE  DateTime?

  unit  Units?  @relation(fields: [UNIT_ID], references: [UNIT_ID])
  forms Forms[]

  @@index([UNIT_ID])
  @@map("SECTIONS")
}

model Doctors {
  DOCTOR_ID        Int     @id @default(autoincrement())
  DOCTOR_NAME      String? @db.VarChar(255)
  DOCTORS_TYPE     String? @db.VarChar(50)
  QULIFICATION     String? @db.VarChar(255)
  GLOBAL_DOCTOR_ID Int?

  @@map("DOCTORS")
}

model Transfer {
  TRANSFER_ID        Int       @id @default(autoincrement())
  EMPLOYEE_ID        Int?
  T_FROM             String?   @db.VarChar(255)
  T_TO               String?   @db.VarChar(255)
  TRANSFER_DATE      DateTime?
  RELEASE_DATE       DateTime?
  RESUMPTION_DATE    DateTime?
  C_BY               String?   @db.VarChar(100)
  C_DATE             DateTime?
  LAST_MODIFIED_BY   String?   @db.VarChar(100)
  LAST_MODIFIED_DATE DateTime?

  @@index([EMPLOYEE_ID])
  @@map("TRANSFER")
}

model Promotions {
  PROMOTION_ID       Int       @id @default(autoincrement())
  OLD_GRADE_ID       Int?
  OLD_STEP_ID        Int?
  OLD_SALARY_TABLE_ID Int?
  NEW_GRADE_ID       Int?
  NEW_STEP_ID        Int?
  NEW_SALARY_TABLE_ID Int?
  CREATED_BY         String?   @db.VarChar(100)
  CREATED_DATE       DateTime?
  EMPLOYEE_ID        Int?
  PROMOTION_DATE     DateTime?
  DISCRIPTION        String?   @db.VarChar(500)
  PROMOTION_TYPE     String?   @db.VarChar(50)

  @@index([EMPLOYEE_ID])
  @@map("PROMOTIONS")
}

model DoctorTransferHistory {
  DOCTOR_TRANSFER_HISTORY_ID Int       @id @default(autoincrement())
  USER_ID                    Int?
  CURRENT_CLINIC             Int?
  NEW_CLINIC                 Int?
  CREATED_DATE               DateTime?

  @@map("DOCTOR_TRANSFER_HISTORY")
}
