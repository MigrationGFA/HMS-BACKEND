// Legacy: ITEMS (medications), BATCHED_ITEMS, DRUG_CHART linked via clinical, STORES for dispense

// Pharmacy-specific models live mostly in ITEMS (IS_MEDICATION) + REQUEST_DETAILS + STORES.
// Additional pharmacy/drug catalog tables:

model MasterDrugs {
  ID_1               Int     @id @default(autoincrement())
  ID                 Int?
  DISPLAY_NAME       String? @db.VarChar(255)
  GENERIC_NAME       String? @db.VarChar(255)
  PROPRIETARY_NAME   String? @db.VarChar(255)
  DOSAGE             String? @db.VarChar(100)
  DOSAGE_FORM        String? @db.VarChar(100)
  MANUFACTURER__NAME String? @db.VarChar(255)
  PACK_SIZE          String? @db.VarChar(50)
  DEFAULT_INDICATION String? @db.VarChar(500)

  @@map("MASTER_DRUGS")
}

model DrugConsumableTypes {
  DRUG_CONSUMABLE_TYPE_ID Int     @id @default(autoincrement())
  DRUG_CONSUMABLE_NAME    String? @db.VarChar(255)
  SUB_ITEM_TYPE           String? @db.VarChar(50)

  @@map("DRUG_CONSUMABLE_TYPES")
}

model BatchedItems {
  BATCHED_ITEM_ID Int       @id @default(autoincrement())
  STORE_ID        Int?
  ITEM_ID         Int?
  BATCH_NO        String?   @db.VarChar(100)
  QTY_IN          Decimal?  @db.Decimal(14, 2)
  CREATED_DATE    DateTime?
  CREATED_BY      String?   @db.VarChar(100)
  EXPIRY_DATE     DateTime?
  QTY_BAL         Decimal?  @db.Decimal(14, 2)

  store Stores? @relation(fields: [STORE_ID], references: [STORE_ID])
  item  Items?  @relation(fields: [ITEM_ID], references: [ITEM_ID])
  transactions Transactions[]

  @@index([STORE_ID, ITEM_ID])
  @@map("BATCHED_ITEMS")
}

model Batches {
  BATCH_ID     Int       @id @default(autoincrement())
  QTY          Decimal?  @db.Decimal(14, 2)
  CREATED_BY   String?   @db.VarChar(100)
  CREATED_DATE DateTime?

  @@map("BATCHES")
}

model Packs {
  PACK_ID      Int       @id @default(autoincrement())
  PACK_NAME    String?   @db.VarChar(255)
  CREATED_BY   String?   @db.VarChar(100)
  CREATED_DATE DateTime?
  UPDATED_DATE DateTime?
  UPDATED_BY   String?   @db.VarChar(100)

  details PackDetails[]

  @@map("PACKS")
}

model PackDetails {
  PACK_DETAIL_ID Int      @id @default(autoincrement())
  PACK_ID        Int?
  ITEM_ID        Int?
  QTY            Decimal? @db.Decimal(12, 2)

  pack Packs? @relation(fields: [PACK_ID], references: [PACK_ID])
  item Items? @relation(fields: [ITEM_ID], references: [ITEM_ID])

  @@index([PACK_ID])
  @@map("PACK_DETAILS")
}
