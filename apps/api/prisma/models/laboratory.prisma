// Legacy: REQUEST_FORM, REQUEST_DETAILS, TEST_GROUP, TEST_RESULT, TEST_CODE, LIS_ORDER, MACHINES

model RequestForm {
  REQUEST_FORM_ID          Int       @id @default(autoincrement())
  REQUEST_TYPE             String?   @db.VarChar(50)
  BILL_TYPE                String?   @db.VarChar(50)
  DOCTOR_ID                Int?
  REQUEST_DATE             DateTime?
  IS_COMPLETED             String?   @db.VarChar(10)
  PERSON_ID                Int?
  ADMISSION_ID             Int?
  STATUS                   String?   @db.VarChar(50)
  ENTERED_BY               String?   @db.VarChar(100)
  IS_PAID                  String?   @db.VarChar(10)
  BILL_ID                  Int?
  DOCTOR_COMMENT           String?   @db.Text
  LAB_COMMENT              String?   @db.Text
  MSG_LOG_ID               Int?
  CREATED_BY               String?   @db.VarChar(100)
  BILLINGSHEET_ID          Int?
  RESULT_TEMPLATE          String?   @db.Text
  TEST_GROUP_ID            Int?
  RESULT_MSG_LOG_ID        Int?
  CLINIC_ID                Int?
  REQUEST_REASON           String?   @db.VarChar(500)
  BRANCH_ID                Int?
  HOSPITAL_ID              Int?
  CASE_FILE_ID             Int?
  REQUEST_SUB_TYPE         String?   @db.VarChar(50)
  IN_OUT_PATIENT_REQUEST   String?   @db.VarChar(20)

  person      Persons?    @relation(fields: [PERSON_ID], references: [PERSON_ID])
  admission   Admission?  @relation(fields: [ADMISSION_ID], references: [ADMISSION_ID])
  clinic      Clinics?    @relation(fields: [CLINIC_ID], references: [CLINIC_ID])
  caseFile    CaseFile?   @relation(fields: [CASE_FILE_ID], references: [CASE_FILE_ID])
  testGroup   TestGroup?  @relation(fields: [TEST_GROUP_ID], references: [TEST_GROUP_ID])
  details     RequestDetails[]
  testResults TestResult[]

  @@index([PERSON_ID])
  @@index([STATUS])
  @@index([REQUEST_TYPE])
  @@map("REQUEST_FORM")
}

model RequestDetails {
  REQUEST_DETAIL_ID        Int       @id @default(autoincrement())
  REQUEST_FORM_ID          Int?
  ITEM_ID                  Int?
  ITEM_TYPE                String?   @db.VarChar(50)
  QTY                      Decimal?  @db.Decimal(12, 2)
  M                        String?   @db.VarChar(10)
  A                        String?   @db.VarChar(10)
  N                        String?   @db.VarChar(10)
  SALES_PRICE              Decimal?  @db.Decimal(12, 2)
  TOTAL                    Decimal?  @db.Decimal(12, 2)
  OBSERVATION              String?   @db.Text
  CONCLUSION               String?   @db.Text
  REMARK                   String?   @db.Text
  FREQUENCY                String?   @db.VarChar(50)
  FREQUENCY_TYPE           String?   @db.VarChar(50)
  DURATION                 String?   @db.VarChar(50)
  CREATED_DATE             DateTime?
  PROCESSED_TIME           String?   @db.VarChar(50)
  PROCESSED_DATE           DateTime?
  CREATED_BY               String?   @db.VarChar(100)
  IS_BILLED                String?   @db.VarChar(10)
  UPDATED_DATE             DateTime?
  UPDATED_BY               String?   @db.VarChar(100)
  FLAG                     String?   @db.VarChar(10)
  DRUG_CHART_FLAG          String?   @db.VarChar(10)
  DRUG_ADMIN_COUNT         Int?
  DRUG_CHART_COUNT         Int?
  DRUG_NOTE_COUNT          Int?
  REFILL_QTY               Decimal?  @db.Decimal(12, 2)
  RXCUI_NO                 String?   @db.VarChar(50)
  DRUG_AVAILABILITY_STATUS String?   @db.VarChar(50)
  REQUEST_EXPIRY_DATE      DateTime?
  AUTHORIZATION_CODE       String?   @db.VarChar(100)

  requestForm RequestForm? @relation(fields: [REQUEST_FORM_ID], references: [REQUEST_FORM_ID])
  item        Items?       @relation(fields: [ITEM_ID], references: [ITEM_ID])
  testResults TestResult[]

  @@index([REQUEST_FORM_ID])
  @@index([ITEM_ID])
  @@map("REQUEST_DETAILS")
}

model TestGroup {
  TEST_GROUP_ID   Int     @id @default(autoincrement())
  TEST_NAME       String? @db.VarChar(255)
  TEST_GROUP_TYPE String? @db.VarChar(50)

  requestForms RequestForm[]
  subGroups    SubGroup[]
  testCodes    TestCode[]
  bills        Bills[]
  items        Items[]
  machines     Machines[]

  @@map("TEST_GROUP")
}

model SubGroup {
  SUB_GROUP_ID   Int     @id @default(autoincrement())
  TEST_GROUP_ID  Int?
  SUB_GROUP_NAME String? @db.VarChar(255)

  testGroup TestGroup? @relation(fields: [TEST_GROUP_ID], references: [TEST_GROUP_ID])
  items     Items[]

  @@index([TEST_GROUP_ID])
  @@map("SUB_GROUP")
}

model TestCode {
  TEST_CODE_ID  Int       @id @default(autoincrement())
  LIS_CODE      String?   @db.VarChar(50)
  TEST_CODE     String?   @db.VarChar(50)
  TEST_NAME     String?   @db.VarChar(255)
  CREATED_DATE  DateTime?
  UPDATED_BY    String?   @db.VarChar(100)
  UPDATED_DATE  DateTime?
  SAMPLE_TYPE   String?   @db.VarChar(50)
  TEST_GROUP_ID Int?
  DEPARTMENT    String?   @db.VarChar(100)
  DESCRIPTION   String?   @db.VarChar(500)
  CREATED_BY    String?   @db.VarChar(100)
  LOINC_CODE    String?   @db.VarChar(50)

  testGroup TestGroup? @relation(fields: [TEST_GROUP_ID], references: [TEST_GROUP_ID])

  @@map("TEST_CODE")
}

model TestDetails {
  TEST_DETAIL_ID Int     @id @default(autoincrement())
  ITEM_ID        Int?
  TEST_NAME      String? @db.VarChar(255)
  L_BAND         String? @db.VarChar(50)
  H_BAND         String? @db.VarChar(50)
  UOM            String? @db.VarChar(50)
  LIS_CODE       String? @db.VarChar(50)

  item        Items?       @relation(fields: [ITEM_ID], references: [ITEM_ID])
  testResults TestResult[]

  @@index([ITEM_ID])
  @@map("TEST_DETAILS")
}

model TestResult {
  TEST_RESULT_ID       Int       @id @default(autoincrement())
  REQUEST_DETAIL_ID    Int?
  ITEM_ID              Int?
  TEST_VALUE           String?   @db.VarChar(500)
  L_BAND               String?   @db.VarChar(50)
  H_BAND               String?   @db.VarChar(50)
  TEST_DETAIL_ID       Int?
  REQUEST_FORM_ID      Int?
  RESULT_TEMPLATE      String?   @db.Text
  UOM                  String?   @db.VarChar(50)
  BILL_DETAIL_ID       Int?
  TEST_NAME            String?   @db.VarChar(255)
  FLAG                 String?   @db.VarChar(10)
  LIS_CODE             String?   @db.VarChar(50)
  LAB_NO               String?   @db.VarChar(50)
  PERSON_ID            Int?
  SAMPLE_ID            String?   @db.VarChar(100)
  MACHINE_ID           Int?
  CREATED_DATE         DateTime?
  RESULT_RECEIVED_DATE DateTime?
  STATUS               String?   @db.VarChar(50)
  SAMPLE_ID_BACKUP     String?   @db.VarChar(100)

  requestDetail RequestDetails? @relation(fields: [REQUEST_DETAIL_ID], references: [REQUEST_DETAIL_ID])
  requestForm   RequestForm?    @relation(fields: [REQUEST_FORM_ID], references: [REQUEST_FORM_ID])
  testDetail    TestDetails?    @relation(fields: [TEST_DETAIL_ID], references: [TEST_DETAIL_ID])
  item          Items?          @relation(fields: [ITEM_ID], references: [ITEM_ID])
  machine       Machines?       @relation(fields: [MACHINE_ID], references: [MACHINE_ID])

  @@index([REQUEST_FORM_ID])
  @@index([SAMPLE_ID])
  @@map("TEST_RESULT")
}

model LisOrder {
  LIS_ORDER_ID       Int       @id @default(autoincrement())
  REQUEST_ID         Int?
  ORDER_RESULT       String?   @db.Text
  SAMPLE_ID          String?   @db.VarChar(100)
  STATUS             String?   @db.VarChar(50)
  MACHINE_CODE       String?   @db.VarChar(50)
  CREATED_DATE       DateTime?
  CREATED_BY         String?   @db.VarChar(100)
  UPDATED_BY         String?   @db.VarChar(100)
  UPDATED_DATE       DateTime?
  MACHINE_TYPE       String?   @db.VarChar(50)
  HOSPITAL_ID        Int?
  BRANCH_ID          Int?
  REQUESTED_DATE     DateTime?
  RECEIVED_DATE      DateTime?
  ORDER_REQUEST      String?   @db.Text
  STUDY_UID          String?   @db.VarChar(100)
  IS_RESULT_ANALYZED String?   @db.VarChar(10)
  PERSON_ID          Int?
  SAMPLE_ID_BACKUP   String?   @db.VarChar(100)

  @@index([SAMPLE_ID])
  @@index([PERSON_ID])
  @@map("LIS_ORDER")
}

model Machines {
  MACHINE_ID                 Int     @id @default(autoincrement())
  MACHINE_NAME               String? @db.VarChar(255)
  MACHINE_CODE               String? @db.VarChar(50)
  MANUFACTURE_NAME           String? @db.VarChar(255)
  MACHINE_TYPE               String? @db.VarChar(50)
  HOSPITAL_ID                Int?
  BRANCH_ID                  Int?
  MACHINE_SUB_TYPE           String? @db.VarChar(50)
  TEST_GROUP_ID              Int?
  PROVIDER_NAME              String? @db.VarChar(255)
  REMOTE_HOST                String? @db.VarChar(255)
  REMOTE_PORT                Int?
  REMOTE_PROTOCOL            String? @db.VarChar(50)
  REMOTE_TCP_TX_TIMEOUT      Int?
  REMOTE_HTTP_USERNAME       String? @db.VarChar(100)
  REMOTE_HTTP_PASSWORD       String? @db.VarChar(255)
  REMOTE_HTTP_CONTEXT_PATH   String? @db.VarChar(255)
  LOCAL_HOST                 String? @db.VarChar(255)
  LOCAL_PORT                 Int?
  LOCAL_PROTOCOL             String? @db.VarChar(50)
  LOCAL_TCP_TX_TIMEOUT       Int?
  LOCAL_HTTP_USERNAME        String? @db.VarChar(100)
  LOCAL_HTTP_PASSWORD        String? @db.VarChar(255)
  LOCAL_HTTP_CONTEXT_PATH    String? @db.VarChar(255)
  ANALYZER_PARSER_HANDLER    String? @db.VarChar(255)

  testGroup   TestGroup?    @relation(fields: [TEST_GROUP_ID], references: [TEST_GROUP_ID])
  testResults TestResult[]
  items       Items[]

  @@map("MACHINES")
}

model MachineParameter {
  MACHINE_PARAMETER_ID Int     @id @default(autoincrement())
  MACHINE_ID           Int?
  LIS_CODE             String? @db.VarChar(50)
  MACHINE_TEST_CODE    String? @db.VarChar(50)

  @@map("MACHINE_PARAMETER")
}
