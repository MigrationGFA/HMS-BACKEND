// Legacy: radiology/imaging is primarily REQUEST_FORM (REQUEST_TYPE) + PACS_STUDY_TEST + BILL_DETIALS.PACS_IMAGE_URL

model PacsStudyTest {
  ACCESSION  String  @id @db.VarChar(100)
  STUDY_UID  String? @db.VarChar(255)

  @@map("PACS_STUDY_TEST")
}

model Drawings {
  DRAWINGS_ID   Int     @id @default(autoincrement())
  PERSON_ID     Int?
  DRAWING       Bytes?
  COMMENT_DRAW  String? @db.Text
  DOCUMENT_CATIG String? @db.VarChar(100)
  NAME          String? @db.VarChar(255)
  MSG_LOG_ID    Int?
  MIME_TYPE     String? @db.VarChar(100)

  @@index([PERSON_ID])
  @@map("DRAWINGS")
}

model Ophthalmology {
  OPHTHALMOLOGY_ID         Int     @id @default(autoincrement())
  PERSON_ID                Int?
  ADMISSION_ID             Int?
  CASE_FILE_ID             Int?
  LENS_TYPE                String? @db.VarChar(100)
  LENS_FOR                 String? @db.VarChar(100)
  FRAME_TYPE               String? @db.VarChar(100)
  LENSE_SIDE               String? @db.VarChar(50)
  REMARK                   String? @db.Text
  OD_FUNDUS_IMG_ID         Int?
  OS_FUNDUS_IMG_ID         Int?
  OD_ANTERIOR_IMG_ID       Int?
  OS_ANTERIOR_IMG_ID       Int?
  REFRACTIVE_ERRORS_TYPE   String? @db.VarChar(100)

  details OphthalmologyDetails[]

  @@index([PERSON_ID])
  @@map("OPHTHALMOLOGY")
}

model OphthalmologyDetails {
  OPHTHALMOLOGY_DETAIL_ID Int      @id @default(autoincrement())
  EYE                     String?  @db.VarChar(10)
  SPH                     String?  @db.VarChar(50)
  CYL                     String?  @db.VarChar(50)
  AXIS                    String?  @db.VarChar(50)
  VD                      String?  @db.VarChar(50)
  NEAR_ADD                String?  @db.VarChar(50)
  VN                      String?  @db.VarChar(50)
  OPHTHALMOLOGY_ID        Int?

  ophthalmology Ophthalmology? @relation(fields: [OPHTHALMOLOGY_ID], references: [OPHTHALMOLOGY_ID])

  @@index([OPHTHALMOLOGY_ID])
  @@map("OPHTHALMOLOGY_DETAILS")
}

model LensType {
  LENS_ID   Int     @id @default(autoincrement())
  LENS_NAME String? @db.VarChar(100)
  LENS_TYPE String? @db.VarChar(50)

  @@map("LENS_TYPE")
}
