// Legacy: NOTIFICATIONS, CHATS, CHAT_THREADS, MEDICAL_REPORT

model Notifications {
  NOTIFICATION_ID    Int       @id @default(autoincrement())
  USER_ID            Int?
  DESCRIPTION        String?   @db.Text
  CATEGORY           String?   @db.VarChar(50)
  IS_READ            String?   @db.VarChar(10)
  CREATED_BY         String?   @db.VarChar(100)
  CREATED_DATE       DateTime?
  SOUND_FLAG         String?   @db.VarChar(10)
  CHAT_THREAD_ID     Int?
  NOTIFICATION_GROUP String?   @db.VarChar(50)
  MSG_LOG_ID         Int?
  APPOINTMENT_ID     Int?

  user        Users?        @relation(fields: [USER_ID], references: [USER_ID])
  appointment Appoitements? @relation(fields: [APPOINTMENT_ID], references: [APPOINTMENT_ID])
  chatThread  ChatThreads?  @relation(fields: [CHAT_THREAD_ID], references: [CHAT_THREAD_ID])

  @@index([USER_ID])
  @@index([IS_READ])
  @@map("NOTIFICATIONS")
}

model ChatThreads {
  CHAT_THREAD_ID Int  @id @default(autoincrement())
  FIRST_USER_ID  Int?
  SECOND_USER_ID Int?

  chats         Chats[]
  notifications Notifications[]

  @@map("CHAT_THREADS")
}

model Chats {
  CHAT_ID        Int       @id @default(autoincrement())
  USER_ID        Int?
  MESSAGE        String?   @db.Text
  CREATED_DATE   DateTime?
  CHAT_THREAD_ID Int?

  chatThread ChatThreads? @relation(fields: [CHAT_THREAD_ID], references: [CHAT_THREAD_ID])

  @@index([CHAT_THREAD_ID])
  @@map("CHATS")
}

model MedicalReport {
  MEDICAL_REPORT_ID Int       @id @default(autoincrement())
  PERSON_ID         Int?
  ADMISSION_ID      Int?
  CREATED_DATE      DateTime?
  CREATED_BY        String?   @db.VarChar(100)
  UPDATE_DATE       DateTime?
  UPDATE_BY         String?   @db.VarChar(100)
  APPROVED_BY       String?   @db.VarChar(100)
  APPROVED_DATE     DateTime?
  NOTE              String?   @db.Text
  APPROVED          String?   @db.VarChar(10)

  @@index([PERSON_ID])
  @@map("MEDICAL_REPORT")
}

model GenericTemplates {
  GENERIC_TEMPLATE_ID Int     @id @default(autoincrement())
  CONTENT             String? @db.Text
  TEMPLATE_NAME       String? @db.VarChar(255)
  TEMPLATE_TYPE       String? @db.VarChar(50)

  details GenericTemplateDetails[]

  @@map("GENERIC_TEMPLATES")
}

model GenericTemplateDetails {
  GENERIC_TEMPLATE_DETAIL_ID Int     @id @default(autoincrement())
  GENERIC_TEMPLATE_ID        Int?
  P_TITLE                    String? @db.VarChar(255)
  CONTROL                    String? @db.VarChar(100)
  SORT_NO                    Int?

  template GenericTemplates? @relation(fields: [GENERIC_TEMPLATE_ID], references: [GENERIC_TEMPLATE_ID])

  @@index([GENERIC_TEMPLATE_ID])
  @@map("GENERIC_TEMPLATE_DETAILS")
}
