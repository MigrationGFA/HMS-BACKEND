// Legacy: ITEMS, STORES, STORE_ITEMS, STORE_REQUEST, LPO, GRN, TRANSACTIONS, SUPPLIERS via LPO

model Items {
  ITEM_ID                Int       @id @default(autoincrement())
  ITEM_NAME              String?   @db.VarChar(255)
  C_DATE                 DateTime?
  WATCH_LIST             String?   @db.VarChar(10)
  OUT_OF_STOCK_LEVEL     Decimal?  @db.Decimal(14, 2)
  SELLING_PRICE          Decimal?  @db.Decimal(12, 2)
  PURCHASE_PRICE         Decimal?  @db.Decimal(12, 2)
  BALANCE                Decimal?  @db.Decimal(14, 2)
  FLAG                   String?   @db.VarChar(10)
  ITEM_CODE              String?   @db.VarChar(50)
  SUPPLIER_ID            Int?
  BARCODE                String?   @db.VarChar(100)
  OPENING_STOCK_BAL      Decimal?  @db.Decimal(14, 2)
  COA_ID                 Int?
  ITEM_TYPE              String?   @db.VarChar(50)
  UOM                    String?   @db.VarChar(50)
  SERVICE_LOCATION       String?   @db.VarChar(100)
  TEST_GROUP_ID          Int?
  ITEM_CATEGORY          String?   @db.VarChar(50)
  DRUG_TYPE              String?   @db.VarChar(50)
  DRUG_STRENGTH          String?   @db.VarChar(50)
  ALLOW_POSTING_FORM_POST String?  @db.VarChar(10)
  GENERIC_TEMPLATE_ID    Int?
  RESULT_TEMPLATE        String?   @db.Text
  NHIS_COA_ID            Int?
  SERVICE_COA_ID         Int?
  SUB_GROUP_ID           Int?
  TEST_GROUP_NAME        String?   @db.VarChar(255)
  PACK_SIZE              String?   @db.VarChar(50)
  DISCONTINUE_FLAG       String?   @db.VarChar(10)
  IS_BATCHED_INVENTORY   String?   @db.VarChar(10)
  NHIS_FLAG              String?   @db.VarChar(10)
  NHIS_PRICE             Decimal?  @db.Decimal(12, 2)
  FPP_PRICE              Decimal?  @db.Decimal(12, 2)
  RETAINERSHIP_PRICE     Decimal?  @db.Decimal(12, 2)
  ITEM_DESCRIPTION       String?   @db.Text
  IS_MEDICATION          String?   @db.VarChar(10)
  ACCESSIBILITY          String?   @db.VarChar(50)
  MACHINE_ID             Int?
  SUB_ITEM_TYPE          String?   @db.VarChar(50)
  BRANCH_ID              Int?
  ITEM_RECEIVED_IN       String?   @db.VarChar(50)
  ITEM_DISPENSED_IN      String?   @db.VarChar(50)
  GENERIC_NAME           String?   @db.VarChar(255)
  RXCUI_NO               String?   @db.VarChar(50)
  DRUG_SYNONYM           String?   @db.VarChar(255)
  CREATED_BY             String?   @db.VarChar(100)
  CREATED_DATE           DateTime?
  UPDATED_BY             String?   @db.VarChar(100)
  UPDATED_DATE           DateTime?

  coa            Coa?             @relation(fields: [COA_ID], references: [COA_ID])
  testGroup      TestGroup?       @relation(fields: [TEST_GROUP_ID], references: [TEST_GROUP_ID])
  subGroup       SubGroup?        @relation(fields: [SUB_GROUP_ID], references: [SUB_GROUP_ID])
  machine        Machines?        @relation(fields: [MACHINE_ID], references: [MACHINE_ID])
  storeItems     StoreItems[]
  storeRequestDetails StoreRequestDetails[]
  batchedItems   BatchedItems[]
  packDetails    PackDetails[]
  priceList      PriceList[]
  billDetails    BillDetials[]
  requestDetails RequestDetails[]
  testDetails    TestDetails[]
  testResults    TestResult[]
  lpoDetails     LpoDetails[]
  grnDetails     GrnDetails[]
  transactions   Transactions[]
  claimDetails   ClaimDetails[]
  bundleDetails  BundleDetails[]

  @@index([ITEM_CODE])
  @@index([ITEM_TYPE])
  @@index([IS_MEDICATION])
  @@map("ITEMS")
}

model Stores {
  STORE_ID     Int     @id @default(autoincrement())
  STORE_NAME   String? @db.VarChar(255)
  IS_WAREHOUSE String? @db.VarChar(10)
  STORE_TYPE   String? @db.VarChar(50)
  HOSPITAL_ID  Int?
  BRANCH_ID    Int?
  DISCONTINUE  String? @db.VarChar(10)

  hospital        Hospitals?       @relation(fields: [HOSPITAL_ID], references: [HOSPITAL_ID])
  branch          Branches?        @relation(fields: [BRANCH_ID], references: [BRANCH_ID])
  storeItems      StoreItems[]
  batchedItems    BatchedItems[]
  bills           Bills[]
  users           Users[]
  storeRequestDetails StoreRequestDetails[]
  transactions    Transactions[]
  lpo             Lpo[]
  grn             Grn[]
  itemReturned    ItemReturned[]

  @@index([HOSPITAL_ID, BRANCH_ID])
  @@map("STORES")
}

model StoreItems {
  STORE_ITEM_ID      Int      @id @default(autoincrement())
  STORE_ID           Int?
  ITEM_ID            Int?
  BALANCE            Decimal? @db.Decimal(14, 2)
  FLAG               String?  @db.VarChar(10)
  PURCHASE_PRICE     Decimal? @db.Decimal(12, 2)
  OPENING_STOCK_BAL  Decimal? @db.Decimal(14, 2)
  DISCONTINUE_FLAG   String?  @db.VarChar(10)
  TOTAL_COST         Decimal? @db.Decimal(18, 2)
  AVG_UNIT_COST      Decimal? @db.Decimal(14, 4)
  OPENING_TEMP       Decimal? @db.Decimal(14, 2)

  store Stores? @relation(fields: [STORE_ID], references: [STORE_ID])
  item  Items?  @relation(fields: [ITEM_ID], references: [ITEM_ID])

  @@index([STORE_ID, ITEM_ID])
  @@map("STORE_ITEMS")
}

model StoreRequest {
  STORE_REQUEST_ID   Int       @id @default(autoincrement())
  REQUEST_FROM       Int?
  REQUEST_TO         Int?
  CREATED_BY         String?   @db.VarChar(100)
  CREATED_DATE       DateTime?
  STATUS             String?   @db.VarChar(50)
  IS_COMPLETED       String?   @db.VarChar(10)
  APPROVED_BY        String?   @db.VarChar(100)
  APPROVED_DATE      DateTime?
  STORE_REQUEST_TYPE String?   @db.VarChar(50)
  DONOR_ID           Int?
  PERSON_ID          Int?
  SUPPLIER_ID        Int?
  MACHINE_ID         Int?
  LOCATION_ID        Int?
  HOSPITAL_ID        Int?
  BRANCH_ID          Int?

  details StoreRequestDetails[]

  @@map("STORE_REQUEST")
}

model StoreRequestDetails {
  STORE_REQ_DETAIL_ID Int       @id @default(autoincrement())
  ITEM_ID             Int?
  STORE_ID            Int?
  QTY                 Decimal?  @db.Decimal(14, 2)
  STORE_REQUEST_ID    Int?
  APPROVED_QTY        Decimal?  @db.Decimal(14, 2)
  REQUESTED_QTY       Decimal?  @db.Decimal(14, 2)
  UNIT                String?   @db.VarChar(50)
  BATCH_NO            String?   @db.VarChar(100)
  EXPIRY_DATE         DateTime?
  COLLECTION_DATE     DateTime?
  HIV                 String?   @db.VarChar(20)
  HVC                 String?   @db.VarChar(20)
  BATCH_ID            Int?
  ITEM_RECEIVED_IN    String?   @db.VarChar(50)

  storeRequest StoreRequest? @relation(fields: [STORE_REQUEST_ID], references: [STORE_REQUEST_ID])
  item         Items?        @relation(fields: [ITEM_ID], references: [ITEM_ID])
  store        Stores?       @relation(fields: [STORE_ID], references: [STORE_ID])

  @@index([STORE_REQUEST_ID])
  @@map("STORE_REQUEST_DETAILS")
}

model Lpo {
  LPO_ID              Int       @id @default(autoincrement())
  STORE_ID            Int?
  SUPPLIER_ID         Int?
  CREATED_BY          String?   @db.VarChar(100)
  CREATED_DATE        DateTime?
  COUNT               Int?
  PROPOSED_AMOUNT     Decimal?  @db.Decimal(14, 2)
  APPROVED_AMOUNT     Decimal?  @db.Decimal(14, 2)
  VET_AMOUNT          Decimal?  @db.Decimal(14, 2)
  FIRST_APPROVAL      String?   @db.VarChar(10)
  SECOND_APPROVAL     String?   @db.VarChar(10)
  FIRST_APPROVAL_DATE DateTime?
  SECOND_APPROVAL_DATE DateTime?
  STATUS              String?   @db.VarChar(50)
  BILL_ID             Int?
  DEPARTMENT_ID       Int?
  FIRST_APPROVAL_BY   String?   @db.VarChar(100)
  SECOND_APPROVAL_BY  String?   @db.VarChar(100)

  store   Stores?      @relation(fields: [STORE_ID], references: [STORE_ID])
  details LpoDetails[]
  grn     Grn[]
  grnDetails GrnDetails[]

  @@map("LPO")
}

model LpoDetails {
  LPO_DETAIL_ID       Int      @id @default(autoincrement())
  LPO_ID              Int?
  ITEM_ID             Int?
  UNIT                String?  @db.VarChar(50)
  REQUESTED_QUANTITY  Decimal? @db.Decimal(14, 2)
  REQUESTED_PRICE     Decimal? @db.Decimal(12, 2)
  APPROVED_QUANTITY   Decimal? @db.Decimal(14, 2)
  APPROVED_PRICE      Decimal? @db.Decimal(12, 2)
  REQUEST_TOTAL       Decimal? @db.Decimal(14, 2)
  APPROVED_TOTAL      Decimal? @db.Decimal(14, 2)
  IS_CONVERTED_TO_GRN String?  @db.VarChar(10)

  lpo     Lpo?         @relation(fields: [LPO_ID], references: [LPO_ID])
  item    Items?       @relation(fields: [ITEM_ID], references: [ITEM_ID])
  grnDetails GrnDetails[]

  @@index([LPO_ID])
  @@map("LPO_DETAILS")
}

model Grn {
  GRN_ID              Int       @id @default(autoincrement())
  LPO_ID              Int?
  STORE_ID            Int?
  SUPPLIER_ID         Int?
  CREATED_BY          String?   @db.VarChar(100)
  CREATED_DATE        DateTime?
  COUNT               Int?
  PROPOSED_AMOUNT     Decimal?  @db.Decimal(14, 2)
  APPROVED_AMOUNT     Decimal?  @db.Decimal(14, 2)
  VET_AMOUNT          Decimal?  @db.Decimal(14, 2)
  FIRST_APPROVAL      String?   @db.VarChar(10)
  SECOND_APPROVAL     String?   @db.VarChar(10)
  FIRST_APPROVAL_DATE DateTime?
  SECOND_APPROVAL_DATE DateTime?
  STATUS              String?   @db.VarChar(50)
  BILL_ID             Int?
  DEPARTMENT_ID       Int?
  FIRST_APPROVAL_BY   String?   @db.VarChar(100)
  SECOND_APPROVAL_BY  String?   @db.VarChar(100)

  lpo     Lpo?         @relation(fields: [LPO_ID], references: [LPO_ID])
  store   Stores?      @relation(fields: [STORE_ID], references: [STORE_ID])
  details GrnDetails[]

  @@map("GRN")
}

model GrnDetails {
  GRN_DETAIL_ID            Int      @id @default(autoincrement())
  GRN_ID                   Int?
  LPO_DETAIL_ID            Int?
  LPO_ID                   Int?
  ITEM_ID                  Int?
  UNIT                     String?  @db.VarChar(50)
  REQUESTED_QUANTITY       Decimal? @db.Decimal(14, 2)
  REQUESTED_PRICE          Decimal? @db.Decimal(12, 2)
  APPROVED_QUANTITY        Decimal? @db.Decimal(14, 2)
  APPROVED_PRICE           Decimal? @db.Decimal(12, 2)
  REQUEST_TOTAL            Decimal? @db.Decimal(14, 2)
  APPROVED_TOTAL           Decimal? @db.Decimal(14, 2)
  IS_CONVERTED_TO_INVOICE  String?  @db.VarChar(10)

  grn       Grn?        @relation(fields: [GRN_ID], references: [GRN_ID])
  lpoDetail LpoDetails? @relation(fields: [LPO_DETAIL_ID], references: [LPO_DETAIL_ID])
  lpo       Lpo?        @relation(fields: [LPO_ID], references: [LPO_ID])
  item      Items?      @relation(fields: [ITEM_ID], references: [ITEM_ID])

  @@index([GRN_ID])
  @@map("GRN_DETAILS")
}

model Transactions {
  TRANSACTION_ID  Int       @id @default(autoincrement())
  ITEM_ID         Int?
  BATCH_NO        String?   @db.VarChar(100)
  DESCRIPTION     String?   @db.VarChar(500)
  QTY_IN          Decimal?  @db.Decimal(14, 2)
  QTY_OUT         Decimal?  @db.Decimal(14, 2)
  BALANCE         Decimal?  @db.Decimal(14, 2)
  I_DATE          DateTime?
  AMOUNT          Decimal?  @db.Decimal(14, 2)
  ENTERED_BY      String?   @db.VarChar(100)
  PURCHASED_PRICE Decimal?  @db.Decimal(12, 2)
  EXPIRY_DATE     DateTime?
  TOTAL           Decimal?  @db.Decimal(14, 2)
  INVOICE_ID      Int?
  P_BALANCE       Decimal?  @db.Decimal(14, 2)
  ACTION          String?   @db.VarChar(50)
  STORE_ID        Int?
  TOTAL_COST_BAL  Decimal?  @db.Decimal(18, 2)
  AVG_UNIT_COST   Decimal?  @db.Decimal(14, 4)
  BATCHED_ITEM_ID Int?

  item         Items?        @relation(fields: [ITEM_ID], references: [ITEM_ID])
  store        Stores?       @relation(fields: [STORE_ID], references: [STORE_ID])
  batchedItem  BatchedItems? @relation(fields: [BATCHED_ITEM_ID], references: [BATCHED_ITEM_ID])

  @@index([ITEM_ID, STORE_ID])
  @@map("TRANSACTIONS")
}

model ItemReturned {
  ITEM_RETURNED_ID Int       @id @default(autoincrement())
  RETURNED_BY      String?   @db.VarChar(100)
  RETURN_TYPE      String?   @db.VarChar(50)
  RETURN_DATE      DateTime?
  STORE_ID         Int?
  DESCRIPTION      String?   @db.VarChar(500)

  store   Stores?              @relation(fields: [STORE_ID], references: [STORE_ID])
  details ItemReturnedDetail[]

  @@map("ITEM_RETURNED")
}

model ItemReturnedDetail {
  ITEM_RETURNED_DETAIL_ID Int       @id @default(autoincrement())
  ITEM_RETURNED_ID        Int?
  ITEM_ID                 Int?
  QTY                     Decimal?  @db.Decimal(14, 2)
  BATCH_NO                String?   @db.VarChar(100)
  EXPIRY_DATE             DateTime?
  AVG_UNIT_COST           Decimal?  @db.Decimal(14, 4)
  TOTAL                   Decimal?  @db.Decimal(14, 2)

  itemReturned ItemReturned? @relation(fields: [ITEM_RETURNED_ID], references: [ITEM_RETURNED_ID])

  @@index([ITEM_RETURNED_ID])
  @@map("ITEM_RETURNED_DETAIL")
}

model Bundles {
  BUNDLE_ID    Int       @id @default(autoincrement())
  BUNDLE_NAME  String?   @db.VarChar(255)
  CREATED_BY   String?   @db.VarChar(100)
  CREATED_DATE DateTime?
  UPDATED_BY   String?   @db.VarChar(100)
  UPDATED_DATE DateTime?
  BUNDLE_TYPE  String?   @db.VarChar(50)

  details BundleDetails[]

  @@map("BUNDLES")
}

model BundleDetails {
  BUNDLE_DETAIL_ID Int      @id @default(autoincrement())
  BUNDLE_ID        Int?
  ITEM_ID          Int?
  ITEM_TYPE        String?  @db.VarChar(50)
  QTY              Decimal? @db.Decimal(12, 2)
  NOTE             String?  @db.VarChar(500)
  ITEM_GROUP_ID    Int?

  bundle Bundles? @relation(fields: [BUNDLE_ID], references: [BUNDLE_ID])
  item   Items?   @relation(fields: [ITEM_ID], references: [ITEM_ID])

  @@index([BUNDLE_ID])
  @@map("BUNDLE_DETAILS")
}
