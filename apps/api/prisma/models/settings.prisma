// Legacy: HOSPITALS, BRANCHES, DEPARTMENTS, CLINICS, APP_PARAMETER, CITIES, STATES, COUNTRIES

model Hospitals {
  HOSPITAL_ID         Int       @id @default(autoincrement())
  HOSPITAL_NAME       String?   @db.VarChar(255)
  MY_HOSPITAL_FLAG    String?   @db.VarChar(10)
  HOSPITAL_TYPE       String?   @db.VarChar(50)
  LICENSE_NO          String?   @db.VarChar(100)
  HOSPITAL_CODE       String?   @db.VarChar(50)
  APP_URL             String?   @db.VarChar(500)
  ACTIVATION_DATE     DateTime?
  LICENSE_EXPIRY_DATE DateTime?
  GLOBAL_HOSPITAL_ID  Int?
  HOSPITAL_LOGO       Bytes?
  BRANCH_ID           Int?
  HOSPITAL_ALISE      String?   @db.VarChar(100)

  branches Branches[]
  users    Users[]
  persons  Persons[]
  clinics  Clinics[]
  wards    Wards[]
  stores   Stores[]

  @@map("HOSPITALS")
}

model Branches {
  BRANCH_ID                Int     @id @default(autoincrement())
  BRANCH_NAME              String? @db.VarChar(255)
  ADDRESS                  String? @db.VarChar(500)
  PHONE_NO                 String? @db.VarChar(50)
  EMAIL                    String? @db.VarChar(255)
  CITY_ID                  Int?
  STATE_ID                 Int?
  BRANCH_CODE              String? @db.VarChar(50)
  HOSPITAL_ID              Int?
  INSURANCE_PROVIDER_ID    Int?
  INSURANCE_USERNAME       String? @db.VarChar(100)
  INSURANCE_USERID         String? @db.VarChar(100)
  INSURANCE_PASSWORD       String? @db.VarChar(255)
  INSURANCE_ATTENDINGOFFICER String? @db.VarChar(255)
  GLOBAL_BRANCH_ID         Int?
  BRANCH_ALISE             String? @db.VarChar(100)

  hospital Hospitals? @relation(fields: [HOSPITAL_ID], references: [HOSPITAL_ID])
  users    Users[]
  persons  Persons[]
  clinics  Clinics[]
  beds     Beds[]
  wards    Wards[]
  stores   Stores[]

  @@index([HOSPITAL_ID])
  @@map("BRANCHES")
}

model Departments {
  DEPARTMENT_ID Int     @id @default(autoincrement())
  NAME          String? @db.VarChar(255)

  clinics Clinics[]

  @@map("DEPARTMENTS")
}

model Clinics {
  CLINIC_ID                      Int     @id @default(autoincrement())
  CLINIC_NAME                    String? @db.VarChar(255)
  DESCRIPTION                    String? @db.VarChar(500)
  CONSULTATION_FEE_ID            Int?
  IS_PRIMARY_CLINIC              String? @db.VarChar(10)
  DEPARTMENT_ID                  Int?
  IS_CONSULTATION_FREE           String? @db.VarChar(10)
  CLINIC_DAYS                    String? @db.VarChar(100)
  APPOINTMENT_COUNTER            Int?
  HOSPITAL_ID                    Int?
  BRANCH_ID                      Int?
  CLINIC_CATEGORY                String? @db.VarChar(50)
  CARD_FEE_ID                    Int?
  CLINIC_CODE                    String? @db.VarChar(50)
  DISCONTINUE_FLAG               String? @db.VarChar(10)
  IS_DISCONTINUED                String? @db.VarChar(10)
  CASE_FILE_DURATION_INPATIENT   Int?
  CASE_FILE_DURATION_OUTPATIENT  Int?
  CONSULTATION_FEE_DURATION      Int?

  department   Departments? @relation(fields: [DEPARTMENT_ID], references: [DEPARTMENT_ID])
  hospital     Hospitals?   @relation(fields: [HOSPITAL_ID], references: [HOSPITAL_ID])
  branch       Branches?    @relation(fields: [BRANCH_ID], references: [BRANCH_ID])
  users        Users[]
  appointments Appoitements[]
  bills        Bills[]
  requestForms RequestForm[]

  @@index([DEPARTMENT_ID])
  @@index([HOSPITAL_ID, BRANCH_ID])
  @@map("CLINICS")
}

model AppParameter {
  APP_PARAMETER_ID        Int     @id @default(autoincrement())
  PARAMETER_NAME          String? @db.VarChar(255)
  PARAMETER_VALUE         String? @db.VarChar(1000)
  BRANCH_ID               Int?
  AVAILABLE_TO            String? @db.VarChar(100)
  PARAMETER_TYPE          String? @db.VarChar(50)
  PARAMETER_DESCRIPTION   String? @db.VarChar(500)
  HOSPITAL_ID             Int?
  MASTER_APP_PARAMETER_ID Int?
  SORT_NO                 Int?

  @@map("APP_PARAMETER")
}

model Countries {
  COUNTRY_ID   Int     @id @default(autoincrement())
  COUNTRY_NAME String? @db.VarChar(100)
  COUNTRY_CODE String? @db.VarChar(10)

  states States[]

  @@map("COUNTRIES")
}

model States {
  STATE_ID   Int     @id @default(autoincrement())
  STATE_NAME String? @db.VarChar(100)
  COUNTRY_ID Int?

  country Countries? @relation(fields: [COUNTRY_ID], references: [COUNTRY_ID])
  cities  Cities[]
  lgas    Lga[]

  @@index([COUNTRY_ID])
  @@map("STATES")
}

model Cities {
  CITY_ID   Int     @id @default(autoincrement())
  CITY_NAME String? @db.VarChar(100)
  STATE_ID  Int?

  state States? @relation(fields: [STATE_ID], references: [STATE_ID])

  @@index([STATE_ID])
  @@map("CITIES")
}

model Lga {
  LGA_ID   Int     @id @default(autoincrement())
  STATE_ID Int?
  LGA_NAME String? @db.VarChar(100)

  state States? @relation(fields: [STATE_ID], references: [STATE_ID])

  @@index([STATE_ID])
  @@map("LGA")
}

model Occupations {
  OCCUPATION_ID Int     @id @default(autoincrement())
  NAME          String? @db.VarChar(255)
  CODE          String? @db.VarChar(50)

  @@map("OCCUPATIONS")
}
