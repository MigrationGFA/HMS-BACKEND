// Legacy: BILLS, BILL_DETIALS, BILLINGSHEET, INVOICES, PRICE_LIST, PAYMENT_CHANNEL, CASHIER_LEDGER, CASH_REVENUE, TRANS

model Billingsheet {
  BILLINGSHEET_ID   Int       @id @default(autoincrement())
  NAME              String?   @db.VarChar(255)
  CREATED_DATE      DateTime?
  CREATED_BY        String?   @db.VarChar(100)
  BILLINGSHEET_TYPE String?   @db.VarChar(50)

  bills Bills[]

  @@map("BILLINGSHEET")
}

model Bills {
  BILL_ID               Int       @id @default(autoincrement())
  PERSON_ID             Int?
  REQUEST_TYPE          String?   @db.VarChar(50)
  BILL_TYPE             String?   @db.VarChar(50)
  BILL_DATE             DateTime?
  DOCTOR_ID             Int?
  REQUEST_FORM_ID       Int?
  BILL_AMOUNT           Decimal?  @db.Decimal(14, 2)
  CASH_AMOUNT           Decimal?  @db.Decimal(14, 2)
  IS_COMPLETED          String?   @db.VarChar(10)
  IS_PAID               String?   @db.VarChar(10)
  AMOUNT_PAID           Decimal?  @db.Decimal(14, 2)
  OUT_STANDING_BAL      Decimal?  @db.Decimal(14, 2)
  ADMISSION_ID          Int?
  BILLED_FROM           String?   @db.VarChar(100)
  IS_SERVICED           String?   @db.VarChar(10)
  SUPPLIER_ID           Int?
  INVOICE_NO            String?   @db.VarChar(100)
  CASHIER_ID            Int?
  CASH_RECEIVED_DATE    DateTime?
  IS_REVERSED           String?   @db.VarChar(10)
  DISPENSED_DRUG        String?   @db.VarChar(10)
  BILLINGSHEET_ID       Int?
  STORE_ID              Int?
  BILL_TITLE            String?   @db.VarChar(255)
  TEST_GROUP_ID         Int?
  TRANS_ID              Int?
  BILL_BY               String?   @db.VarChar(100)
  CASH_CREDIT           String?   @db.VarChar(20)
  CREDIT_ACCT_ID        Int?
  CREDIT_AMOUNT         Decimal?  @db.Decimal(14, 2)
  AUTHORIZATION_CODE    String?   @db.VarChar(100)
  RESULT_TEMPLATE       String?   @db.Text
  TEST_RESULT_STATUS    String?   @db.VarChar(50)
  TEST_RESULT_COMMENT   String?   @db.Text
  RESULT_ENTERED_BY     String?   @db.VarChar(100)
  RESULT_MSG_LOG_ID     Int?
  CREDIT_STATUS         String?   @db.VarChar(50)
  ALLOW_SERVICE         String?   @db.VarChar(10)
  CLINIC_ID             Int?
  HOSPITAL_ID           Int?
  BRANCH_ID             Int?
  GRN_ID                Int?
  MARKED_FOR_PAYMENT    String?   @db.VarChar(10)
  PATIENT_PAYMENT_VAL   Decimal?  @db.Decimal(14, 2)
  INSURANCE_PAYMENT_VAL Decimal?  @db.Decimal(14, 2)
  STATUS                String?   @db.VarChar(50)
  APPROVED_BY           String?   @db.VarChar(100)
  INVOICE_ID            Int?
  PAYMENT_TRANS_ID      Int?

  person       Persons?     @relation(fields: [PERSON_ID], references: [PERSON_ID])
  admission    Admission?   @relation(fields: [ADMISSION_ID], references: [ADMISSION_ID])
  billingsheet Billingsheet? @relation(fields: [BILLINGSHEET_ID], references: [BILLINGSHEET_ID])
  clinic       Clinics?     @relation(fields: [CLINIC_ID], references: [CLINIC_ID])
  store        Stores?      @relation(fields: [STORE_ID], references: [STORE_ID])
  testGroup    TestGroup?   @relation(fields: [TEST_GROUP_ID], references: [TEST_GROUP_ID])
  invoice      Invoices?    @relation(fields: [INVOICE_ID], references: [INVOICE_ID])
  details      BillDetials[]
  cashierLedger CashierLedger[]
  cashRevenue  CashRevenue[]
  transactions Trans[]

  @@index([PERSON_ID])
  @@index([IS_PAID])
  @@index([BILL_DATE])
  @@map("BILLS")
}

model BillDetials {
  BILL_DETAIL_ID           Int       @id @default(autoincrement())
  ITEM_ID                  Int?
  QTY                      Decimal?  @db.Decimal(12, 2)
  SALES_PRICE              Decimal?  @db.Decimal(12, 2)
  TOTAL                    Decimal?  @db.Decimal(12, 2)
  BILL_ID                  Int?
  IS_PAID                  String?   @db.VarChar(10)
  AMOUNT_COLLECTED         Decimal?  @db.Decimal(12, 2)
  COA_HEAD                 String?   @db.VarChar(100)
  PURCHASE_PRICE           Decimal?  @db.Decimal(12, 2)
  DESCRIPTION              String?   @db.VarChar(500)
  SUPPLIED_QTY             Decimal?  @db.Decimal(12, 2)
  UNIT                     String?   @db.VarChar(50)
  BILLINGSHEET_ID          Int?
  REVOLVING_PRICE          Decimal?  @db.Decimal(12, 2)
  SERVICE_CHARGE_PRICE     Decimal?  @db.Decimal(12, 2)
  REVOLVING_INCOME_HEAD    String?   @db.VarChar(100)
  SERVICE_INCOME_HEAD      String?   @db.VarChar(100)
  LAB_NO                   String?   @db.VarChar(50)
  QIC                      String?   @db.VarChar(50)
  BATCH_NO                 String?   @db.VarChar(100)
  EXPIRY_DATE              DateTime?
  RESULT_TEMPLATE          String?   @db.Text
  TEST_RESULT_STATUS       String?   @db.VarChar(50)
  TEST_RESULT_COMMENT      String?   @db.Text
  RESULT_ENTERED_BY        String?   @db.VarChar(100)
  RESULT_MSG_LOG_ID        Int?
  REQUEST_FORM_ID          Int?
  PERSON_ID                Int?
  COLLECTION_DATE          DateTime?
  PACS_IMAGE_URL           String?   @db.VarChar(500)
  PATIENT_PAYMENT_VAL      Decimal?  @db.Decimal(12, 2)
  INSURANCE_PAYMENT_VAL    Decimal?  @db.Decimal(12, 2)
  PATIENT_PERCENTAGE_VAL   Decimal?  @db.Decimal(8, 2)
  INSURANCE_PERCENTAGE_VAL Decimal?  @db.Decimal(8, 2)
  PACK_PURCHASE_PRICE      Decimal?  @db.Decimal(12, 2)
  PACK_SALES_PRICE         Decimal?  @db.Decimal(12, 2)
  MARKUP_PERCENTAGE        Decimal?  @db.Decimal(8, 2)
  MARKUP_VALUE             Decimal?  @db.Decimal(12, 2)
  ITEM_RECEIVED_IN         String?   @db.VarChar(50)
  ITEM_DESPENSED_IN        String?   @db.VarChar(50)
  MACHINE_ORDER_STATUS     String?   @db.VarChar(50)
  INVOICE_ID               Int?
  PAYMENT_TRANS_ID         Int?

  bill Bills? @relation(fields: [BILL_ID], references: [BILL_ID])
  item Items? @relation(fields: [ITEM_ID], references: [ITEM_ID])
  claimDetails ClaimDetails[]

  @@index([BILL_ID])
  @@index([ITEM_ID])
  @@map("BILL_DETIALS")
}

model Invoices {
  INVOICE_ID       Int       @id @default(autoincrement())
  INVOICE_NO       String?   @db.VarChar(100)
  PERSON_ID        Int?
  ADMISSION_ID     Int?
  INVOICE_TYPE     String?   @db.VarChar(50)
  INVOICE_STATUS   String?   @db.VarChar(50)
  SUBTOTAL         Decimal?  @db.Decimal(14, 2)
  TAX_NAME         String?   @db.VarChar(100)
  TAX_RATE         Decimal?  @db.Decimal(8, 4)
  TAX_AMOUNT       Decimal?  @db.Decimal(14, 2)
  DISCOUNT_NAME    String?   @db.VarChar(100)
  DISCOUNT_RATE    Decimal?  @db.Decimal(8, 4)
  DISCOUNT_AMOUNT  Decimal?  @db.Decimal(14, 2)
  TOTAL_AMOUNT     Decimal?  @db.Decimal(14, 2)
  PAYMENT_TERMS    String?   @db.VarChar(255)
  PAYMENT_METHOD   String?   @db.VarChar(50)
  CURRENCY_ID      Int?
  CREATED_BY       String?   @db.VarChar(100)
  CREATED_DATE     DateTime?
  UPDATED_BY       String?   @db.VarChar(100)
  UPDATED_DATE     DateTime?

  person    Persons?  @relation(fields: [PERSON_ID], references: [PERSON_ID])
  admission Admission? @relation(fields: [ADMISSION_ID], references: [ADMISSION_ID])
  bills     Bills[]
  transactions Trans[]

  @@index([PERSON_ID])
  @@index([INVOICE_NO])
  @@map("INVOICES")
}

model PriceList {
  PRICE_LIST_ID            Int       @id @default(autoincrement())
  OWNER_ID                 Int?
  ITEM_ID                  Int?
  AMOUNT                   Decimal?  @db.Decimal(12, 2)
  CREATED_BY               String?   @db.VarChar(100)
  CREATED_DATE             DateTime?
  UPDATED_BY               String?   @db.VarChar(100)
  UPDATED_DATE             DateTime?
  FLAG                     String?   @db.VarChar(10)
  SERVICE_AMOUNT           Decimal?  @db.Decimal(12, 2)
  IS_SECONDARY_CARE        String?   @db.VarChar(10)
  DISCONTINUE_FLAG         String?   @db.VarChar(10)
  HOSPITAL_ID              Int?
  BRANCH_ID                Int?
  PATIENT_PERCENTAGE_VAL   Decimal?  @db.Decimal(8, 2)
  INSURANCE_PERCENTAGE_VAL Decimal?  @db.Decimal(8, 2)
  PATIENT_PAYMENT_VAL      Decimal?  @db.Decimal(12, 2)
  INSURANCE_PAYMENT_VAL    Decimal?  @db.Decimal(12, 2)
  PACK_PRICE               Decimal?  @db.Decimal(12, 2)
  UNIT_PRICE               Decimal?  @db.Decimal(12, 2)

  item Items? @relation(fields: [ITEM_ID], references: [ITEM_ID])

  @@index([ITEM_ID])
  @@map("PRICE_LIST")
}

model PaymentChannel {
  PAYMENT_CHANNEL_ID Int     @id @default(autoincrement())
  NAME               String? @db.VarChar(100)
  COA_ID             Int?
  STATUS             String? @db.VarChar(50)

  transactions Trans[]

  @@map("PAYMENT_CHANNEL")
}

model CashierLedger {
  CASHIER_LEDGER_ID Int       @id @default(autoincrement())
  CASHIER_ID        Int?
  BILL_ID           Int?
  DESCRIPTION       String?   @db.VarChar(500)
  AMOUNT            Decimal?  @db.Decimal(14, 2)
  CREATED_DATE      DateTime?
  CREATED_DATE_TIME DateTime?
  PERSON_ID         Int?
  TRANS_ID          Int?
  CREDIT            String?   @db.VarChar(10)

  bill Bills? @relation(fields: [BILL_ID], references: [BILL_ID])

  @@index([CASHIER_ID])
  @@map("CASHIER_LEDGER")
}

model CashRevenue {
  CASH_REVENUE_ID   Int       @id @default(autoincrement())
  CASHIER_ID        Int?
  BILL_ID           Int?
  DESCRIPTION       String?   @db.VarChar(500)
  AMOUNT            Decimal?  @db.Decimal(14, 2)
  CREATED_DATE      DateTime?
  CREATED_DATE_TIME DateTime?
  PERSON_ID         Int?
  TRANS_ID          Int?
  CREDIT            String?   @db.VarChar(10)
  COA_ID            Int?

  bill Bills? @relation(fields: [BILL_ID], references: [BILL_ID])

  @@index([CASHIER_ID])
  @@map("CASH_REVENUE")
}

model Trans {
  TRANS_ID               Int       @id @default(autoincrement())
  H_DR                   String?   @db.VarChar(50)
  SH_DR                  String?   @db.VarChar(50)
  H_CR                   String?   @db.VarChar(50)
  SH_CR                  String?   @db.VarChar(50)
  TRANS_TYPE             String?   @db.VarChar(50)
  TRANS_METHOD           String?   @db.VarChar(50)
  AMOUNT                 Decimal?  @db.Decimal(14, 2)
  NARRATION              String?   @db.VarChar(500)
  IS_REVERSE             String?   @db.VarChar(10)
  TRANS_DATE             DateTime?
  CREATED_BY             String?   @db.VarChar(100)
  PASSED_BY              String?   @db.VarChar(100)
  TRANS_STATUS           String?   @db.VarChar(50)
  F_YEAR_ID              Int?
  BRANCH_ID              Int?
  CR_DR                  String?   @db.VarChar(10)
  BILL_ID                Int?
  SOURCE                 String?   @db.VarChar(100)
  PERSON_ID              Int?
  PAYMENT_CHANNEL_ID     Int?
  PAYMENT_REF            String?   @db.VarChar(100)
  APPLY_WALLET_CREDIT    String?   @db.VarChar(10)
  AUTHORIZATION_CODE     String?   @db.VarChar(100)
  UNDO_TRANS_ID          Int?
  IS_UNDO_TRANSLATION    String?   @db.VarChar(10)
  TRANS_LOCK             String?   @db.VarChar(10)
  HOSPITAL_ID            Int?
  PROFIT_LOSS_ACCT_ID    Int?
  TRANS_PURPOSE          String?   @db.VarChar(100)
  EXTERNAL_TRANS_REF     String?   @db.VarChar(100)
  INVOICE_ID             Int?
  APPROVED_BY            String?   @db.VarChar(100)

  bill           Bills?          @relation(fields: [BILL_ID], references: [BILL_ID])
  invoice        Invoices?       @relation(fields: [INVOICE_ID], references: [INVOICE_ID])
  paymentChannel PaymentChannel? @relation(fields: [PAYMENT_CHANNEL_ID], references: [PAYMENT_CHANNEL_ID])

  @@index([BILL_ID])
  @@index([PERSON_ID])
  @@map("TRANS")
}
