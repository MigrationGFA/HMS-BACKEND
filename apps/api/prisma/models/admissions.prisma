// Legacy: ADMISSION, WARDS, BEDS, ADMISSION_HISTORY, ADMISSION_WAITING_LIST, ADMISSION_BUNDLES, CASE_FILE

model Wards {
  WARD_ID          Int     @id @default(autoincrement())
  WARD_NAME        String? @db.VarChar(255)
  DESCRIPTION      String? @db.VarChar(500)
  GENDER           String? @db.VarChar(20)
  HOSPITAL_ID      Int?
  BRANCH_ID        Int?
  ITEM_ID          Int?
  DISCONTINUE_FLAG String? @db.VarChar(10)

  hospital  Hospitals?  @relation(fields: [HOSPITAL_ID], references: [HOSPITAL_ID])
  branch    Branches?   @relation(fields: [BRANCH_ID], references: [BRANCH_ID])
  beds      Beds[]
  admissions Admission[]
  users     Users[]
  history   AdmissionHistory[]
  waitingList AdmissionWaitingList[]
  nursesReports NursesReportSheet[]
  drugCharts DrugChart[]

  @@index([HOSPITAL_ID, BRANCH_ID])
  @@map("WARDS")
}

model Beds {
  BED_ID      Int      @id @default(autoincrement())
  BED_NO      String?  @db.VarChar(50)
  WARDS_ID    Int?
  COST_OF_BED Decimal? @db.Decimal(12, 2)
  INCOME_HEAD String?  @db.VarChar(100)
  AVAILABILITY String? @db.VarChar(20)
  BRANCH_ID   Int?
  HOSPITAL_ID Int?

  ward   Wards?    @relation(fields: [WARDS_ID], references: [WARD_ID])
  branch Branches? @relation(fields: [BRANCH_ID], references: [BRANCH_ID])
  history AdmissionHistory[]

  @@index([WARDS_ID])
  @@map("BEDS")
}

model Admission {
  ADMISSION_ID            Int       @id @default(autoincrement())
  ADMISSION_DATE          DateTime?
  ADMISSION_CLASS         String?   @db.VarChar(50)
  LOCATION_ID             Int?
  DIAGNOSIS               String?   @db.VarChar(1000)
  REFERRED_BY             String?   @db.VarChar(255)
  THERAPY                 String?   @db.VarChar(500)
  REFERRER_NOTE           String?   @db.VarChar(1000)
  BILL_TYPE               String?   @db.VarChar(50)
  NHIS_NO                 String?   @db.VarChar(50)
  DISCHARGE_DATE          DateTime?
  DISCHARGE_TYPE          String?   @db.VarChar(50)
  BED_NO                  String?   @db.VarChar(50)
  PERSON_ID               Int?
  WARD_ID                 Int?
  NURSE_OBSERVATION       String?   @db.Text
  REQUEST_FORM_ID         Int?
  IS_DISCHARGED           String?   @db.VarChar(10)
  CREATED_DATE            DateTime?
  CREATED_BY              String?   @db.VarChar(100)
  DISCHARGE_SUMMARY       String?   @db.Text
  DOCTOR_ID               Int?
  CASE_FILE_ID            Int?
  METHOD_PRESENTATION     String?   @db.VarChar(100)
  NEW_OLD                 String?   @db.VarChar(20)
  CAUSE_OF_DEATH          String?   @db.VarChar(500)
  DISCHARGED_BY           String?   @db.VarChar(100)
  STATUS                  String?   @db.VarChar(50)
  IS_BILL_CLEARED         String?   @db.VarChar(10)
  BILL_CLEARED_BY         String?   @db.VarChar(100)
  AUTHORIZATION_CODE      String?   @db.VarChar(100)
  INSURANCE_COMPANY_ID    Int?
  CLAIM_DIAGNOSIS_LABLE   String?   @db.VarChar(500)
  VISIT_TYPE              String?   @db.VarChar(50)
  HOSPITAL_ID             Int?
  BRANCH_ID               Int?
  IS_URGENT               String?   @db.VarChar(10)
  ADMISSION_BUNDLE_ID     Int?
  PART_OF                 Int?
  APPOINTMENT_ID          Int?
  SESSION_END_TIME        DateTime?
  PERSON_GROUP_ID         Int?
  CLAIM_SUBMISSION_STATUS String?   @db.VarChar(50)
  BILL_CLEARED_DATE       DateTime?
  ADMITTED_BY             String?   @db.VarChar(100)

  person   Persons? @relation(fields: [PERSON_ID], references: [PERSON_ID])
  ward     Wards?   @relation(fields: [WARD_ID], references: [WARD_ID])
  caseFile CaseFile? @relation(fields: [CASE_FILE_ID], references: [CASE_FILE_ID])

  history      AdmissionHistory[]
  waitingList  AdmissionWaitingList[]
  appointments Appoitements[]
  bills        Bills[]
  invoices     Invoices[]
  requestForms RequestForm[]
  diagnoses    Diagnosis[]
  notes        Notes[]
  vitalSigns   VitalSigns[]
  vs           Vs[]
  complaints   Complaints[]
  msgLogs      MsgLogs[]
  drugCharts   DrugChart[]
  nursesReports NursesReportSheet[]
  claimDetails ClaimDetails[]

  @@index([PERSON_ID])
  @@index([WARD_ID])
  @@index([STATUS])
  @@map("ADMISSION")
}

model AdmissionHistory {
  ADMISSION_HISTORY_ID Int       @id @default(autoincrement())
  ADMISSION_ID         Int?
  WARD_ID              Int?
  BED_ID               Int?
  PERSON_ID            Int?
  ADMISSION_DATE       DateTime?
  DISCHARGE_DATE       DateTime?
  FLAG                 String?   @db.VarChar(10)
  CREATED_BY           String?   @db.VarChar(100)
  CREATED_DATE         DateTime?
  DISCHARGE_TYPE       String?   @db.VarChar(50)
  DISCHARGE_BY         String?   @db.VarChar(100)

  admission Admission? @relation(fields: [ADMISSION_ID], references: [ADMISSION_ID])
  ward      Wards?     @relation(fields: [WARD_ID], references: [WARD_ID])
  bed       Beds?      @relation(fields: [BED_ID], references: [BED_ID])

  @@index([ADMISSION_ID])
  @@map("ADMISSION_HISTORY")
}

model AdmissionWaitingList {
  ADMISSION_WAITING_LIST_ID Int       @id @default(autoincrement())
  PERSON_ID                 Int?
  ADMISSION_ID              Int?
  WARD_ID                   Int?
  FLAG                      String?   @db.VarChar(10)
  ADMISSION_TYPE            String?   @db.VarChar(50)
  CREATED_BY                String?   @db.VarChar(100)
  CREATED_DATE              DateTime?
  DESCRIPTION               String?   @db.VarChar(500)

  admission Admission? @relation(fields: [ADMISSION_ID], references: [ADMISSION_ID])
  ward      Wards?     @relation(fields: [WARD_ID], references: [WARD_ID])

  @@index([PERSON_ID])
  @@map("ADMISSION_WAITING_LIST")
}

model AdmissionBundles {
  ADMISSION_BUNDLE_ID Int       @id @default(autoincrement())
  BUNDLE_ID           Int?
  ADMISSION_ID        Int?
  PERSON_ID           Int?
  CRAETED_BY          String?   @db.VarChar(100)
  CREATED_DATE        DateTime?
  UPDATED_BY          String?   @db.VarChar(100)
  UPDATED_DATE        DateTime?

  @@index([ADMISSION_ID])
  @@map("ADMISSION_BUNDLES")
}

model CaseFile {
  CASE_FILE_ID   Int       @id @default(autoincrement())
  CASE_FILE_TYPE String?   @db.VarChar(50)
  DESCRIPTION    String?   @db.VarChar(1000)
  CREATED_DATE   DateTime?
  CREATED_BY     String?   @db.VarChar(100)
  END_DATE       DateTime?
  END_BY         String?   @db.VarChar(100)
  PERSON_ID      Int?
  FLAG           String?   @db.VarChar(10)
  ADMISSION_ID   Int?
  LOCATION_ID    Int?

  person     Persons?    @relation(fields: [PERSON_ID], references: [PERSON_ID])
  admissions Admission[]
  appointments Appoitements[]
  notes      Notes[]
  complaints Complaints[]
  requestForms RequestForm[]

  @@index([PERSON_ID])
  @@map("CASE_FILE")
}
