// Inpatient foundation: wards, beds, admissions

model Wards {
  WARD_ID      Int       @id @default(autoincrement())
  CODE         String    @unique @db.VarChar(50)
  NAME         String    @db.VarChar(150)
  WARD_TYPE    String?   @db.VarChar(50)
  /// General | SemiPrivate | Private | VIP | ICU
  WARD_CLASS   String?   @db.VarChar(40)
  /// Male | Female | Mixed — which patient sex may be admitted
  GENDER       String    @default("Mixed") @db.VarChar(20)
  /// Configured daily bed / accommodation rate (NGN)
  DAILY_BED_RATE Decimal  @default(0) @db.Decimal(14, 2)
  /// Default deposit suggested when admitting to this ward (NGN)
  ADMISSION_DEPOSIT_DEFAULT Decimal @default(0) @db.Decimal(14, 2)
  /// Active | Inactive
  STATUS       String    @default("Active") @db.VarChar(30)
  CREATED_BY   String?   @db.VarChar(100)
  CREATED_DATE DateTime?
  UPDATED_BY   String?   @db.VarChar(100)
  UPDATED_DATE DateTime?

  beds        Beds[]
  admissions  Admissions[]
  admissionRequests AdmissionRequests[]
  transfersFrom PatientTransfers[] @relation("TransferFromWard")
  transfersTo   PatientTransfers[] @relation("TransferToWard")
  clinicalReferrals ClinicalReferrals[]
  nursingShifts NursingShifts[]
  nursingHandovers NursingHandovers[]
  nursingReports NursingReportSnapshots[]

  @@index([GENDER])
  @@index([STATUS])
  @@map("WARDS")
}

model Beds {
  BED_ID       Int       @id @default(autoincrement())
  WARD_ID      Int
  LABEL        String    @db.VarChar(50)
  /// AVAILABLE | OCCUPIED | CLEANING | RESERVED | OUT_OF_SERVICE
  STATUS       String    @default("AVAILABLE") @db.VarChar(30)
  CREATED_BY   String?   @db.VarChar(100)
  CREATED_DATE DateTime?
  UPDATED_BY   String?   @db.VarChar(100)
  UPDATED_DATE DateTime?

  ward       Wards        @relation(fields: [WARD_ID], references: [WARD_ID])
  admissions Admissions[]
  transfers  PatientTransfers[]
  clinicalReferrals ClinicalReferrals[]

  @@unique([WARD_ID, LABEL])
  @@index([WARD_ID])
  @@index([STATUS])
  @@map("BEDS")
}

model Admissions {
  ADMISSION_ID       Int       @id @default(autoincrement())
  PERSON_ID          Int
  WARD_ID            Int?
  BED_ID             Int?
  DIAGNOSIS          String?   @db.Text
  CONSULTANT         String?   @db.VarChar(255)
  ASSIGNED_NURSE     String?   @db.VarChar(255)
  /// Psychiatric | ICU | Child | Psychogeriatric | Addiction | General | Rehab
  ADMISSION_TYPE     String?   @db.VarChar(50)
  /// General | Close | Constant
  SUPERVISION_LEVEL  String?   @db.VarChar(50)
  /// PENDING | BED_ALLOCATED | ADMITTED | ON_LEAVE | DISCHARGE_ORDERED | DISCHARGED | CANCELLED
  STATUS             String    @default("ADMITTED") @db.VarChar(40)
  ADMITTED_AT        DateTime  @default(now())
  DISCHARGE_ORDERED_AT DateTime?
  DISCHARGE_ORDERED_BY String? @db.VarChar(100)
  DISCHARGE_REASON   String?   @db.VarChar(500)
  DISCHARGED_AT      DateTime?
  DISCHARGED_BY      String?   @db.VarChar(100)
  CREATED_BY_ID      Int?
  UPDATED_BY_ID      Int?
  CREATED_BY         String?   @db.VarChar(100)
  CREATED_DATE       DateTime?
  UPDATED_BY         String?   @db.VarChar(100)
  UPDATED_DATE       DateTime?

  person Persons @relation(fields: [PERSON_ID], references: [PERSON_ID])
  ward   Wards?  @relation(fields: [WARD_ID], references: [WARD_ID])
  bed    Beds?   @relation(fields: [BED_ID], references: [BED_ID])

  nursingNotes        NursingNotes[]
  nursingVitals       NursingVitals[]
  nursingCarePlans    NursingCarePlans[]
  nursingObservations NursingObservations[]
  nursingIncidents    NursingIncidents[]
  nursingFormInstances NursingFormInstances[]
  nursingOrders       NursingOrders[]
  nursingTasks        NursingTasks[]
  nursingMarEntries   NursingMarEntries[]
  nursingIcuNotes     NursingIcuNotes[]
  nursingIcuInfusions NursingIcuInfusions[]
  admissionBills      AdmissionBills[]
  patientTransfers    PatientTransfers[]
  clinicalReferrals   ClinicalReferrals[]
  dischargeDrafts     DischargeDrafts[]

  @@index([PERSON_ID])
  @@index([STATUS])
  @@index([WARD_ID])
  @@index([ADMITTED_AT])
  @@map("ADMISSIONS")
}

/// Doctor-initiated admission request (no payment, no bed assignment yet).
model AdmissionRequests {
  ADMISSION_REQUEST_ID   Int       @id @default(autoincrement())
  REQUEST_NO             String    @unique @db.VarChar(50)
  PERSON_ID              Int
  ENCOUNTER_ID           Int?
  WARD_ID                Int?
  WARD_PREFERENCE        String?   @db.VarChar(150)
  /// Routine | Urgent | Emergency
  PRIORITY               String    @default("Routine") @db.VarChar(30)
  PRIORITY_REASON        String?   @db.Text
  /// New admission | Readmission | Transfer-in | Observation | Trial leave return
  ADMISSION_TYPE         String?   @db.VarChar(80)
  ESTIMATED_LOS          String?   @db.VarChar(80)
  PROVISIONAL_DIAGNOSIS  String?   @db.Text
  SECONDARY_DIAGNOSIS    String?   @db.Text
  CLINICAL_INDICATION    String?   @db.Text
  MENTAL_HEALTH_RISK     String?   @db.Text
  PHYSICAL_HEALTH_RISK   String?   @db.Text
  TREATMENT_PLAN         String?   @db.Text
  REQUIRED_MONITORING    String?   @db.VarChar(255)
  /// General | Enhanced | Close | Constant (1:1)
  NURSING_OBSERVATION    String?   @db.VarChar(50)
  ISOLATION_REQUIRED     Boolean   @default(false)
  FALL_RISK              Boolean   @default(false)
  SUICIDE_RISK           Boolean   @default(false)
  VIOLENCE_RISK          Boolean   @default(false)
  WITHDRAWAL_RISK        Boolean   @default(false)
  SPECIAL_BED            String?   @db.VarChar(100)
  CONSENT_STATUS         String?   @db.VarChar(80)
  NOK_INFORMED           String?   @db.VarChar(50)
  CLINIC_DEPARTMENT      String?   @db.VarChar(100)
  DOCTOR_NOTE            String?   @db.Text
  /// Draft | Submitted | UnderReview | Approved | Rejected | Cancelled | Admitted
  STATUS                 String    @default("Submitted") @db.VarChar(40)
  REJECTION_REASON       String?   @db.Text
  REQUESTED_BY_USER_ID   Int?
  REQUESTED_BY           String?   @db.VarChar(150)
  CREATED_BY_ID          Int?
  UPDATED_BY_ID          Int?
  CREATED_BY             String?   @db.VarChar(100)
  CREATED_DATE           DateTime?
  UPDATED_BY             String?   @db.VarChar(100)
  UPDATED_DATE           DateTime?

  person Persons @relation(fields: [PERSON_ID], references: [PERSON_ID])
  ward   Wards?  @relation(fields: [WARD_ID], references: [WARD_ID])
  admissionBills AdmissionBills[]

  @@index([PERSON_ID])
  @@index([STATUS])
  @@index([REQUESTED_BY_USER_ID])
  @@index([CREATED_DATE])
  @@map("ADMISSION_REQUESTS")
}

/// Finance-configured admission package catalogue (cashier never prices manually).
model AdmissionBillingItems {
  ITEM_ID      Int       @id @default(autoincrement())
  ITEM_CODE    String    @unique @db.VarChar(40)
  NAME         String    @db.VarChar(150)
  /// AdmissionFee | Nursing | Folder | Consumables | Deposit | Other
  CATEGORY     String    @db.VarChar(40)
  UNIT_PRICE   Decimal   @db.Decimal(14, 2)
  /// Active | Inactive
  STATUS       String    @default("Active") @db.VarChar(30)
  CREATED_BY   String?   @db.VarChar(100)
  CREATED_DATE DateTime?
  UPDATED_BY   String?   @db.VarChar(100)
  UPDATED_DATE DateTime?

  @@index([STATUS])
  @@index([CATEGORY])
  @@map("ADMISSION_BILLING_ITEMS")
}

/// Auto-posted admission package invoice (Unpaid until cashier confirms).
model AdmissionBills {
  ADMISSION_BILL_ID      Int       @id @default(autoincrement())
  BILL_NO                String    @unique @db.VarChar(50)
  PERSON_ID              Int
  ADMISSION_ID           Int?
  ADMISSION_REQUEST_ID   Int?
  TOTAL_AMOUNT           Decimal   @default(0) @db.Decimal(14, 2)
  /// Unpaid | Paid | Waived
  PAYMENT_STATUS         String    @default("Unpaid") @db.VarChar(30)
  PAYMENT_CHANNEL        String?   @db.VarChar(50)
  PAYMENT_REF            String?   @db.VarChar(100)
  PAID_AT                DateTime?
  PAID_BY                String?   @db.VarChar(100)
  CREATED_BY_ID          Int?
  UPDATED_BY_ID          Int?
  CREATED_BY             String?   @db.VarChar(100)
  CREATED_DATE           DateTime?
  UPDATED_BY             String?   @db.VarChar(100)
  UPDATED_DATE           DateTime?

  person           Persons            @relation(fields: [PERSON_ID], references: [PERSON_ID])
  admission        Admissions?        @relation(fields: [ADMISSION_ID], references: [ADMISSION_ID])
  admissionRequest AdmissionRequests? @relation(fields: [ADMISSION_REQUEST_ID], references: [ADMISSION_REQUEST_ID])
  lines            AdmissionBillLines[]

  @@index([PERSON_ID])
  @@index([ADMISSION_ID])
  @@index([PAYMENT_STATUS])
  @@index([CREATED_DATE])
  @@map("ADMISSION_BILLS")
}

model AdmissionBillLines {
  LINE_ID            Int     @id @default(autoincrement())
  ADMISSION_BILL_ID  Int
  ITEM_CODE          String  @db.VarChar(40)
  DESCRIPTION        String  @db.VarChar(255)
  QTY                Int     @default(1)
  UNIT_PRICE         Decimal @db.Decimal(14, 2)
  LINE_TOTAL         Decimal @db.Decimal(14, 2)

  bill AdmissionBills @relation(fields: [ADMISSION_BILL_ID], references: [ADMISSION_BILL_ID], onDelete: Cascade)

  @@index([ADMISSION_BILL_ID])
  @@map("ADMISSION_BILL_LINES")
}
