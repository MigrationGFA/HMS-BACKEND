// Multi-role patient transfer workflow (doctor request → nurse prepare → bed allocate → receive).
// Soft status transitions only — never hard-delete clinical transfer records.

model PatientTransfers {
  TRANSFER_ID           Int       @id @default(autoincrement())
  TRANSFER_NO           String    @unique @db.VarChar(50)
  PERSON_ID             Int
  ADMISSION_ID          Int?
  /// WardToWard | ClinicToWard | WardToClinic | Department | ICU | ExternalReferral
  TRANSFER_TYPE         String    @db.VarChar(40)
  /// Routine | Urgent | Emergency
  PRIORITY              String    @default("Routine") @db.VarChar(30)
  FROM_WARD_ID          Int?
  TO_WARD_ID            Int?
  TO_WARD_PREFERENCE    String?   @db.VarChar(150)
  DESTINATION_LABEL     String?   @db.VarChar(150)
  ALLOCATED_BED_ID      Int?
  REASON                String    @db.Text
  CLINICAL_NOTES        String?   @db.Text
  HANDOVER_NOTES        String?   @db.Text
  /// Draft | Submitted | NursePreparing | AwaitingBed | BedReserved | ReceivingAccepted | InTransit | Completed | Rejected | Cancelled
  STATUS                String    @default("Submitted") @db.VarChar(40)
  REQUESTED_BY_USER_ID  Int?
  PREPARED_BY_USER_ID   Int?
  PREPARED_AT           DateTime?
  ALLOCATED_BY_USER_ID  Int?
  ALLOCATED_AT          DateTime?
  ACCEPTED_BY_USER_ID   Int?
  ACCEPTED_AT           DateTime?
  DEPARTED_BY_USER_ID   Int?
  DEPARTED_AT           DateTime?
  RECEIVED_BY_USER_ID   Int?
  RECEIVED_AT           DateTime?
  REJECTION_REASON      String?   @db.Text
  EXTERNAL_FACILITY     String?   @db.VarChar(255)
  CREATED_BY_ID         Int?
  CREATED_BY            String?   @db.VarChar(100)
  CREATED_DATE          DateTime?
  UPDATED_BY_ID         Int?
  UPDATED_BY            String?   @db.VarChar(100)
  UPDATED_DATE          DateTime?

  person       Persons                 @relation(fields: [PERSON_ID], references: [PERSON_ID])
  admission    Admissions?             @relation(fields: [ADMISSION_ID], references: [ADMISSION_ID])
  fromWard     Wards?                  @relation("TransferFromWard", fields: [FROM_WARD_ID], references: [WARD_ID])
  toWard       Wards?                  @relation("TransferToWard", fields: [TO_WARD_ID], references: [WARD_ID])
  allocatedBed Beds?                   @relation(fields: [ALLOCATED_BED_ID], references: [BED_ID])
  requestedBy  Users?                  @relation("TransferRequestedBy", fields: [REQUESTED_BY_USER_ID], references: [USER_ID])
  events       PatientTransferEvents[]

  @@index([PERSON_ID])
  @@index([ADMISSION_ID])
  @@index([STATUS])
  @@index([FROM_WARD_ID])
  @@index([TO_WARD_ID])
  @@index([REQUESTED_BY_USER_ID])
  @@index([CREATED_DATE])
  @@map("PATIENT_TRANSFERS")
}

model PatientTransferEvents {
  EVENT_ID       Int       @id @default(autoincrement())
  TRANSFER_ID    Int
  EVENT_TYPE     String    @db.VarChar(50)
  ACTOR_USER_ID  Int?
  ACTOR_LABEL    String?   @db.VarChar(150)
  NOTE           String?   @db.Text
  OLD_STATUS     String?   @db.VarChar(40)
  NEW_STATUS     String?   @db.VarChar(40)
  CREATED_DATE   DateTime  @default(now())

  transfer PatientTransfers @relation(fields: [TRANSFER_ID], references: [TRANSFER_ID])

  @@index([TRANSFER_ID])
  @@index([CREATED_DATE])
  @@map("PATIENT_TRANSFER_EVENTS")
}

/// In-app notifications for doctors, nurses, records, and other roles.
model Notifications {
  NOTIFICATION_ID  Int       @id @default(autoincrement())
  USER_ID          Int
  ROLE_HINT        String?   @db.VarChar(50)
  /// TransferRequested | TransferBedAssigned | TransferAccepted | TransferCompleted | TransferRejected | System | …
  TYPE             String    @db.VarChar(60)
  TITLE            String    @db.VarChar(255)
  BODY             String?   @db.Text
  LINK_PATH        String?   @db.VarChar(255)
  ENTITY           String?   @db.VarChar(80)
  ENTITY_ID        Int?
  PERSON_ID        Int?
  IS_READ          Boolean   @default(false)
  ACKNOWLEDGED_AT  DateTime?
  CREATED_DATE     DateTime  @default(now())

  user Users @relation(fields: [USER_ID], references: [USER_ID])

  @@index([USER_ID, IS_READ, CREATED_DATE])
  @@index([TYPE])
  @@index([PERSON_ID])
  @@map("NOTIFICATIONS")
}
