# Application
PORT=3030
NODE_ENV=development
API_PREFIX=api

# PostgreSQL (primary)
DATABASE_URL="postgresql://postgres:password@localhost:5432/hms?schema=public"

# PostgreSQL read replica (enable when scaling reads)
# DATABASE_READ_URL="postgresql://postgres:password@localhost:5433/hms?schema=public"

# Redis — caching, sessions, BullMQ queues, rate limiting
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ — SMS, email, lab processing, reports, background jobs
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=12h

# Session
SESSION_SECRET=change-me-session-secret

# File storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=
