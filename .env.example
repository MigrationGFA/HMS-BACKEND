# Application
PORT=3000
NODE_ENV=development
API_PREFIX=api

# PostgreSQL — Azure Flexible Server (matches Azure Node.js pg sample)
DATABASE_HOST=your-server.postgres.database.azure.com
DATABASE_USER=your_user
DATABASE_PASSWORD=your_password
DATABASE_NAME=postgres
DATABASE_PORT=5432
DATABASE_SSL_CA_PATH=./certs/DigiCertGlobalRootG2.crt.pem

# Prisma CLI — encode @ in password as %40; use sslmode=verify-full + sslrootcert
DATABASE_URL="postgresql://your_user:your_password@your-server.postgres.database.azure.com:5432/postgres?schema=public&sslmode=verify-full&sslrootcert=./certs/DigiCertGlobalRootG2.crt.pem"

PGSSLROOTCERT=./certs/DigiCertGlobalRootG2.crt.pem

# PostgreSQL read replica (enable when scaling reads)
# DATABASE_READ_URL="postgresql://postgres:password@localhost:5433/hms?schema=public&sslmode=require"

# Redis — caching, sessions, BullMQ queues, rate limiting
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ — SMS, email, lab processing, reports, background jobs
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT — generate random secrets for .env (do not commit real values)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Session
SESSION_SECRET=change-me-session-secret

# File storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=
