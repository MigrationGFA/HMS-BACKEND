# Application
PORT=3030
NODE_ENV=development
API_PREFIX=api

# Frontend origin(s) for CORS (comma-separated). Leave empty to allow any origin.
# FRONTEND_URL=https://your-fnph-aro-frontend.onrender.com
# CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# PostgreSQL — Azure Flexible Server (matches Azure Node.js pg sample)
DATABASE_HOST=db-aro.postgres.database.azure.com
DATABASE_USER=aroadmin
DATABASE_PASSWORD=admin@12345
DATABASE_NAME=postgres
DATABASE_PORT=5432
DATABASE_SSL_CA_PATH=./certs/DigiCertGlobalRootG2.crt.pem

# Prisma CLI — encode @ in password as %40; use sslmode=verify-full + sslrootcert
DATABASE_URL="postgresql://your_user:your_password@your-server.postgres.database.azure.com:5432/postgres?schema=public&sslmode=verify-full&sslrootcert=./certs/DigiCertGlobalRootG2.crt.pem"

PGSSLROOTCERT=./certs/DigiCertGlobalRootG2.crt.pem

# PostgreSQL read replica (enable when scaling reads)
# DATABASE_READ_URL="postgresql://postgres:password@localhost:5433/hms?schema=public&sslmode=require"

# Redis — caching, sessions, BullMQ queues, rate limiting
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ — SMS, email, lab processing, reports, background jobs
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT — generate random secrets for .env (do not commit real values)
JWT_ACCESS_SECRET=ZxXPK4X-CXnb8QnFoHhGtcmRHV-gp8NLbakcKLu5GYWZDK2p6JwTGKAFYgkeBYZgjgfVv7wAwL8VsbThCnBUhA
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=bGAG6gAzG9g2qQVpSzaMkj4oQOZ-N4LUW_s22iqyTG4NpgDRJeY0IFo2VhM-GQ3k0bDk0jYCnOokh2Pw5E6eqg
JWT_REFRESH_EXPIRES_IN=7d

# Session
SESSION_SECRET=PZb-Vd75DZeMe0kvBGzAGHrYxOnYlDNHMTRpC-Ap3YroUqcCbhIJirRiRIcJUNFhL9CGxUXEByj3Eai8DKCBZA

# File storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
